{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/before-and-after/layout,_N_T_/before-and-after/page,_N_T_/before-and-after"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/before-and-after/__PAGE__",
    "/before-and-after",
    "/_index",
    "/_head"
  ]
}