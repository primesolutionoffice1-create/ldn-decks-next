dding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Fair"}],["$","td","3",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Temps dropping below 50°F; many stains won't cure properly"}]]}],["$","tr","5",{"style":{"background":"#fafafa"},"children":[["$","td","0",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600,"color":"inherit"},"children":"Winter"}],["$","td","1",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"December-February"}],["$","td","2",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Not Recommended"}],["$","td","3",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Below curing temp for all stain products"}]]}]]}]]}]}]
56:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":[["$","strong",null,{"children":"Our top recommendation:"}]," Book your ",["$","$L17",null,{"href":"/services/deck-maintenance","style":{"color":"var(--color-primary)","fontWeight":600},"children":"deck staining project"}]," for late September or early October. You get the best weather conditions, contractors are less booked than spring, and your deck is protected heading into winter."]}]
