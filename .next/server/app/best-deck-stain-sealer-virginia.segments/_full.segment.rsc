yle","children":"Some formulas restricted"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","color":"var(--color-primary)"},"children":"Fully compliant"}]]}],["$","tr","7",{"style":{"background":"#fafafa"},"children":[["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600},"children":"Application forgiveness"}],["$","td",null,{"style":"$37:props:children:props:children:1:props:children:0:props:children:1:props:style","children":"Very forgiving — self-levels"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","color":"var(--color-primary)"},"children":"Less forgiving — shows lap marks"}]]}],["$","tr","8",{"style":{"background":"#fff"},"children":[["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600},"children":"Cleanup"}],["$","td",null,{"style":"$37:props:children:props:children:1:props:children:0:props:children:1:props:style","children":"Mineral spirits required"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","color":"var(--color-primary)"},"children":"Soap and water"}]]}],["$","tr","9",{"style":{"background":"#fafafa"},"children":[["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600},"children":"Best Virginia use case"}],["$","td",null,{"style":"$37:props:children:props:children:1:props:children:0:props:children:1:props:style","children":"Hardwood decks, fall application only"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","color":"var(--color-primary)"},"children":"All wood types, spring and fall"}]]}]]}]]}]}]
38:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":[["$","strong",null,{"children":"Our recommendation:"}]," Use water-based for 90% of Virginia deck projects. Reserve oil-based (like Cabot Australian Timber Oil) for hardwood decks (ipe, cumaru, mahogany) applied during dry October weather when humidity drops below 50%."]}]
39:["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem","marginTop":"2.5rem"},"children":"Transparent vs Semi-Transparent vs Solid Stain"}]
3a:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"The opacity level you choose determines how much wood grain shows through and how long the finish lasts. Here's how each performs in Virginia:"}]
3b:["$","div",null,{"style":{"display":"grid","gridTemplateColumns":"1fr 1fr 1fr","gap":"1rem","marginBottom":"2rem"},"children":[["$","div","Transparent",{"style":{"background":"#f0fdf4","border":"1px solid #bbf7d0","borderRadius":8,"padding":"1.25rem"},"children":[["$","h3",null,{"style":{"fontWeight":600,"marginBottom":"0.5rem"},"children":"Transparent"}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Lasts:"}]," ","1-2 years"]}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Pros:"}]," ","Shows full wood grain, natural look"]}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Cons:"}]," ","Minimal UV protection, frequent recoating"]}],["$","p",null,{"style":{"fontSize":"0.85rem","margin":0},"children":[["$","strong",null,{"children":"Best for:"}]," ","New cedar or redwood decks where you want maximum grain visibility"]}]]}],["$","div","Semi-Transparent",{"style":{"background":"#fff7ed","border":"1px solid #fed7aa","borderRadius":8,"padding":"1.25rem"},"children":[["$","h3",null,{"style":{"fontWeight":600,"marginBottom":"0.5rem"},"children":"Semi-Transparent"}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Lasts:"}]," ","2-3 years"]}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Pros:"}]," ","Best balance of protection and grain visibility"]}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Cons:"}]," ","Shows some wear patterns in high-traffic areas"]}],["$","p",null,{"style":{"fontSize":"0.85rem","margin":0},"children":[["$","strong",null,{"children":"Best for:"}]," ","Most Virginia decks — pressure-treated pine, cedar, and older wood"]}]]}],["$","div","Solid",{"style":{"background":"#eff6ff","border":"1px solid #bfdbfe","borderRadius":8,"padding":"1.25rem"},"children":[["$","h3",null,{"style":{"fontWeight":600,"marginBottom":"0.5rem"},"children":"Solid"}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Lasts:"}]," ","4-6 years"]}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Pros:"}]," ","Maximum UV and moisture protection, hides imperfections"]}],["$","p",null,{"style":{"fontSize":"0.85rem","marginBottom":"0.5rem"},"children":[["$","strong",null,{"children":"Cons:"}]," ","Hides wood grain, can peel if not prepped properly"]}],["$","p",null,{"style":{"fontSize":"0.85rem","margin":0},"children":[["$","strong",null,{"children":"Best for:"}]," ","Older weathered decks, wood with significant damage or discoloration"]}]]}]]}]
3c:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":["For most Northern Virginia homeowners with pressure-treated pine decks, ",["$","strong",null,{"children":"semi-transparent is the sweet spot"}],". It adds color depth, provides solid UV protection, and allows the wood grain to show through — which is exactly what most people want."]}]
3d:["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem","marginTop":"2.5rem"},"children":"Why Virginia's Climate Destroys Deck Finishes"}]
3e:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Understanding what your deck stain is up against helps explain why some products fail in Virginia while performing fine elsewhere:"}]
3f:["$","h3",null,{"style":{"fontSize":"1.2rem","fontWeight":600,"margin":"1.5rem 0 0.5rem"},"children":"Humidity (June-September)"}]
40:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Virginia's average summer humidity exceeds 70%, with dew points regularly in the upper 60s and low 70s. This creates two problems: stain can't dry properly during application, and trapped moisture beneath the finish causes blistering and peeling. This is why oil-based stains — which need 24+ hours of dry conditions — are risky summer products in our market."}]
41:["$","h3",null,{"style":"$3f:props:style","children":"UV Exposure"}]
42:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Northern Virginia receives 4.5–5.0 peak sun hours per day during summer. South-facing decks take the worst beating — we've seen transparent sealers fail in as little as 8 months on full-sun exposures. Stains with nano-zinc oxide (like Defy Extreme) provide significantly better UV blocking than standard pigment-only formulas."}]
43:["$","h3",null,{"style":"$3f:props:style","children":"Freeze-Thaw Cycles"}]
44:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Northern Virginia experiences 60–80 freeze-thaw cycles per winter. Water penetrates wood fibers, freezes, expands, and cracks the finish from underneath. This is why penetrating stains (that soak into the wood) outperform film-forming stains (that sit on top) in our climate — there's no surface film to crack."}]
45:["$","h3",null,{"style":"$3f:props:style","children":"Rainfall"}]
46:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Virginia averages 42–44 inches of rain annually, well above the national average of 30 inches. Combined with spring pollen accumulation and fall leaf coverage, moisture sits on deck surfaces for extended periods. Products with strong mildew inhibitors are essential — Thompson's original WaterSeal (without mildewcide) is a common failure we see on Virginia decks."}]
47:["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem","marginTop":"2.5rem"},"children":"How to Apply Deck Stain: Step-by-Step"}]
48:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":["Whether you DIY or ",["$","$L17",null,{"href":"/deck-staining-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600},"children":"hire a professional"}],", proper preparation is 80% of a successful stain job. Here's the process we follow:"]}]
49:["$","h3",null,{"style":"$3f:props:style","children":"Step 1: Pressure Wash (Day 1)"}]
4a:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":[["$","$L17",null,{"href":"/pressure-washing-deck-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600},"children":"Pressure wash"}]," at 1,200–1,500 PSI with a 25-degree fan tip. Stay 6–8 inches from the surface. For grayed or mildewed wood, apply a deck cleaner/brightener first. Never exceed 2,000 PSI on softwood — you'll shred the fibers and the stain will absorb unevenly."]}]
4b:["$","h3",null,{"style":"$3f:props:style","children":"Step 2: Dry Time (Days 2-3)"}]
4c:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Allow 48 hours minimum for the wood to dry after washing. In Virginia's humid months, 72 hours is safer. The wood should feel dry to the touch and pass the water droplet test — a sprinkled drop should absorb within 10 seconds, not bead up."}]
4d:["$","h3",null,{"style":"$3f:props:style","children":"Step 3: Sand if Needed (Day 3)"}]
4e:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"If the wood has raised fibers from pressure washing (common), lightly sand with 80-grit sandpaper. This step is often skipped by DIYers and cheap contractors, but it makes a visible difference in the final finish smoothness."}]
4f:["$","h3",null,{"style":"$3f:props:style","children":"Step 4: Apply First Coat (Day 3-4)"}]
50:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Apply stain with a pump sprayer and immediately back-brush with a quality stain brush or stain pad. Work in manageable sections (2–3 boards at a time) to avoid lap marks. Apply in the direction of the wood grain. Start with railings and verticals, then do the deck surface last."}]
51:["$","h3",null,{"style":"$3f:props:style","children":"Step 5: Second Coat (Day 4-5)"}]
52:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Most semi-transparent stains benefit from a second coat applied wet-on-wet (within 30–60 minutes of the first) or after the manufacturer's recommended recoat time. Two thin coats always outperform one thick coat — thick application is the number one cause of peeling."}]
53:["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem","marginTop":"2.5rem"},"children":"Best Time to Stain a Deck in Virginia"}]
54:["$","p",null,{"style":"$1f:props:children:props:children:1:props:style","children":"Timing is critical in Virginia. Here's our seasonal breakdown:"}]
55:["$","div",null,{"style":{"overflowX":"auto","marginBottom":"2rem"},"children":["$","table",null,{"style":{"width":"100%","borderCollapse":"collapse","fontSize":"0.9rem"},"children":[["$","thead",null,{"children":["$","tr",null,{"style":{"background":"#f5f5f5"},"children":[["$","th","Season",{"style":"$1f:props:children:props:children:5:props:children:props:children:0:props:children:props:children:0:props:style","children":"Season"}],["$","th","Months",{"style":"$1f:props:children:props:children:5:props:children:props:children:0:props:children:props:children:0:props:style","children":"Months"}],["$","th","Rating",{"style":"$1f:props:children:props:children:5:props:children:props:children:0:props:children:props:children:0:props:style","children":"Rating"}],["$","th","Notes",{"style":"$1f:props:children:props:children:5:props:children:props:children:0:props:children:props:children:0:props:style","children":"Notes"}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"style":{"background":"#fff"},"children":[["$","td","0",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600,"color":"inherit"},"children":"Early Spring"}],["$","td","1",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Late March-May"}],["$","td","2",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"#166534"},"children":"Excellent"}],["$","td","3",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Ideal temperatures (55-80°F), moderate humidity, long dry stretches"}]]}],["$","tr","1",{"style":{"background":"#fafafa"},"children":[["$","td","0",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600,"color":"inherit"},"children":"Late Spring"}],["$","td","1",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"June"}],["$","td","2",{"style":{"pad