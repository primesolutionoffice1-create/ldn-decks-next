ntWeight":400},"children":"$$20-$40"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Included"}]]}],["$","tr","3",{"style":{"background":"#fafafa"},"children":[["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600},"children":"Brushes, rollers, tape"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400},"children":"$$30-$50"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Included"}]]}],["$","tr","4",{"style":{"background":"#fff"},"children":[["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600},"children":"Sander rental + sandpaper"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400},"children":"$$40-$60"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"Included"}]]}],["$","tr","5",{"style":{"background":"#fafafa"},"children":[["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600},"children":"Labor"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400},"children":"$$0 (your time: 12-16 hrs)"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400,"color":"inherit"},"children":"$$400-$900"}]]}],["$","tr","6",{"style":{"background":"#f0f0f0"},"children":[["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":700},"children":"Total (300 sqft)"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":700},"children":"$$235-$380"}],["$","td",null,{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":700,"color":"var(--color-primary)"},"children":"$$600-$1,500"}]]