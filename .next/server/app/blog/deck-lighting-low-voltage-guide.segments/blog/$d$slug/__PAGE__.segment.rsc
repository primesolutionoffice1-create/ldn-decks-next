0:{"rsc":["$","$1","c",{"children":[["$","article",null,{"className":"BlogContent-module__WEG1wW__articlePage","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Illuminating Your Deck: Low-Voltage Lighting Guide\",\"image\":[\"https://www.ldndecks.com/showcase/img18.jpeg\"],\"datePublished\":\"2026-02-12T05:00:00.000Z\",\"dateModified\":\"2026-02-12T05:00:00.000Z\",\"author\":[{\"@type\":\"Organization\",\"name\":\"Loudoun Decks Team\",\"url\":\"https://www.ldndecks.com\"}],\"publisher\":{\"@type\":\"Organization\",\"name\":\"Loudoun Decks\",\"url\":\"https://www.ldndecks.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.ldndecks.com/ldndecks-logo.webp\"}},\"description\":\"Extend the usability of your deck deep into the night safely with integrated low-voltage LED landscape and composite lighting systems.\",\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.ldndecks.com/blog/deck-lighting-low-voltage-guide\"},\"isAccessibleForFree\":true,\"inLanguage\":\"en-US\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\".leadParagraph\",\"h1\",\"h2\"]}}"}}],["$","div",null,{"className":"BlogContent-module__WEG1wW__heroSection","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__imgWrapper","children":[["$","$L2",null,{"src":"/showcase/img18.jpeg","alt":"Illuminating Your Deck: Low-Voltage Lighting Guide","fill":true,"className":"BlogContent-module__WEG1wW__heroImg","priority":true,"sizes":"100vw"}],["$","div",null,{"className":"BlogContent-module__WEG1wW__imgOverlay","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__containerLarge","children":[["$","$L3",null,{"href":"/blog","className":"BlogContent-module__WEG1wW__backLink","children":"← Back to News"}],["$","h1",null,{"className":"BlogContent-module__WEG1wW__title","children":"Illuminating Your Deck: Low-Voltage Lighting Guide"}],["$","div",null,{"className":"BlogContent-module__WEG1wW__meta","children":[["$","span",null,{"className":"BlogContent-module__WEG1wW__author","children":["By ","Loudoun Decks Team"]}],["$","span",null,{"className":"BlogContent-module__WEG1wW__divider","children":"•"}],["$","span",null,{"children":"February 12, 2026"}]]}]]}]}]]}]}],["$","div",null,{"className":"BlogContent-module__WEG1wW__contentSection","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__containerNarrow","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__contentBody","children":[["$","p",null,{"className":"BlogContent-module__WEG1wW__leadParagraph","children":"Extend the usability of your deck deep into the night safely with integrated low-voltage LED landscape and composite lighting systems."}],[["$","p","0",{"children":"A deck without integrated lighting is a space that dies the moment the sun goes down. Relying on an aggressive, blinding floodlight attached to your house’s siding ruins the relaxing ambiance of the outdoors. The solution lies in professional, low-voltage LED deck lighting."}],["$","h2","1",{"style":{"marginTop":"40px","marginBottom":"20px","color":"#111"},"children":"The Core Elements of Deck Lighting"}],["$","p","2",{"children":"Our electricians integrate specialized marine-grade lighting fixtures directly into the architecture of your deck during the framing phase, hiding all wiring invisibly within the structural posts."}],["$","h3","3",{"style":{"marginTop":"30px","marginBottom":"15px","color":"#222"},"children":"Stair Riser Lights"}],["$","p","4",{"children":"The most critical lighting element for safety. Small, horizontal LED slits are mortised directly into the vertical risers of your staircase, casting a gentle, downward glow onto each step. This prevents dangerous tripping hazards in the pitch black."}],"$L4","$L5","$L6","$L7","$L8"],"$L9"]}]}]}],"$La"]}],["$Lb"],"$Lc"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Jebrcr4Vyd2YosxlccnHN"}
4:["$","h3","5",{"style":{"marginTop":"30px","marginBottom":"15px","color":"#222"},"children":"Post Cap Lights"}]
5:["$","p","6",{"children":"These are glowing caps placed on top of the 4x4 railing posts around the perimeter of the deck. They serve as a navigational border, emitting a warm, soft halo of light that defines the boundaries of the space without blinding the people sitting nearby."}]
6:["$","h3","7",{"style":{"marginTop":"30px","marginBottom":"15px","color":"#222"},"children":"Under-Rail Sconces"}]
7:["$","p","8",{"children":"For a truly sophisticated aesthetic, tiny hidden LED strips or sconces are mounted flush underneath the top rail of the aluminum railing system. They cast light directly downward onto the deck boards, highlighting the beautiful grain and texture of the TimberTech flooring."}]
8:["$","p","9",{"children":"All of these systems are powered by a central low-voltage transformer plugged into a standard GFCI outlet, and can be fully automated using smart-phone controllers or simple photo-cell timers that turn the deck on at dusk automatically."}]
9:["$","div",null,{"className":"BlogContent-module__WEG1wW__conclusionBox","children":[["$","h3",null,{"children":"Ready to upgrade your outdoor living space?"}],["$","p",null,{"children":"Contact Loudoun Decks today for a free estimate and planning consultation."}],["$","$L3",null,{"href":"/contact","className":"BlogContent-module__WEG1wW__ctaBtn","children":"Get Started"}]]}]
