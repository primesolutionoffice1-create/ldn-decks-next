0:{"rsc":["$","$1","c",{"children":[["$","article",null,{"className":"BlogContent-module__WEG1wW__articlePage","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Navigating Railing Heights: Safety and Local Codes\",\"image\":[\"https://www.ldndecks.com/images/img29.jpeg\"],\"datePublished\":\"2025-11-20T05:00:00.000Z\",\"dateModified\":\"2025-11-20T05:00:00.000Z\",\"author\":[{\"@type\":\"Organization\",\"name\":\"Loudoun Decks Team\",\"url\":\"https://www.ldndecks.com\"}],\"publisher\":{\"@type\":\"Organization\",\"name\":\"Loudoun Decks\",\"url\":\"https://www.ldndecks.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.ldndecks.com/ldndecks-logo.webp\"}},\"description\":\"Building a safe deck means adhering strictly to Virginia Uniform Statewide Building Codes regarding railing heights, spindle spacing, and stairway graspability.\",\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.ldndecks.com/blog/railing-heights-safety-and-codes\"},\"isAccessibleForFree\":true,\"inLanguage\":\"en-US\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\".leadParagraph\",\"h1\",\"h2\"]}}"}}],["$","div",null,{"className":"BlogContent-module__WEG1wW__heroSection","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__imgWrapper","children":[["$","$L2",null,{"src":"/images/img29.jpeg","alt":"Navigating Railing Heights: Safety and Local Codes","fill":true,"className":"BlogContent-module__WEG1wW__heroImg","priority":true,"sizes":"100vw"}],["$","div",null,{"className":"BlogContent-module__WEG1wW__imgOverlay","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__containerLarge","children":[["$","$L3",null,{"href":"/blog","className":"BlogContent-module__WEG1wW__backLink","children":"← Back to News"}],["$","h1",null,{"className":"BlogContent-module__WEG1wW__title","children":"Navigating Railing Heights: Safety and Local Codes"}],["$","div",null,{"className":"BlogContent-module__WEG1wW__meta","children":[["$","span",null,{"className":"BlogContent-module__WEG1wW__author","children":["By ","Loudoun Decks Team"]}],["$","span",null,{"className":"BlogContent-module__WEG1wW__divider","children":"•"}],["$","span",null,{"children":"November 20, 2025"}]]}]]}]}]]}]}],["$","div",null,{"className":"BlogContent-module__WEG1wW__contentSection","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__containerNarrow","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__contentBody","children":[["$","p",null,{"className":"BlogContent-module__WEG1wW__leadParagraph","children":"Building a safe deck means adhering strictly to Virginia Uniform Statewide Building Codes regarding railing heights, spindle spacing, and stairway graspability."}],[["$","p","0",{"children":"A deck railing is not just an aesthetic border; it is a critical life-safety feature. The exact specifications regarding how a railing must be built are tightly regulated by Loudoun County and Fairfax County inspectors. Failure to meet these exact minimums will immediately result in a failed inspection."}],["$","h2","1",{"style":{"marginTop":"40px","marginBottom":"20px","color":"#111"},"children":"Residential Minimum Heights"}],["$","p","2",{"children":"For any single-family residential deck that is 30 inches or more above the adjacent ground level, a guardrail is mandatory. Under current local codes, the top of the railing must sit exactly **36 inches measured vertically** from the surface of the deck board. However, for sheer aesthetics or added security, many homeowners opt to upgrade to a 42-inch railing."}],["$","h3","3",{"style":{"marginTop":"30px","marginBottom":"15px","color":"#222"},"children":"The Sphere Rule"}],"$L4","$L5","$L6"],"$L7"]}]}]}],"$L8"]}],["$L9"],"$La"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Jebrcr4Vyd2YosxlccnHN"}
4:["$","p","4",{"children":"Perhaps the most heavily enforced code is the \"4-inch sphere rule.\" balusters or spindles must be spaced tightly enough that a 4-inch rigid sphere cannot pass through any gap. This code was specifically written to prevent small children from squeezing through the railing system."}]
5:["$","h2","5",{"style":{"marginTop":"40px","marginBottom":"20px","color":"#111"},"children":"Stair Handrails"}]
6:["$","p","6",{"children":"Unlike the perimeter guardrail, staircases require \"graspable\" handrails. These handrails must be installed at a height between 34 and 38 inches from the nose of the stair tread. More importantly, the profile of the handrail must allow the average human hand to wrap entirely around it to prevent falls during icy conditions."}]
7:["$","div",null,{"className":"BlogContent-module__WEG1wW__conclusionBox","children":[["$","h3",null,{"children":"Ready to upgrade your outdoor living space?"}],["$","p",null,{"children":"Contact Loudoun Decks today for a free estimate and planning consultation."}],["$","$L3",null,{"href":"/contact","className":"BlogContent-module__WEG1wW__ctaBtn","children":"Get Started"}]]}]
