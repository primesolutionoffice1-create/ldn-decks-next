0:{"rsc":["$","$1","c",{"children":[["$","article",null,{"className":"BlogContent-module__WEG1wW__articlePage","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Wood Preservatives: How to Stop Rot Before It Starts\",\"image\":[\"https://www.ldndecks.com/images/img14.jpeg\"],\"datePublished\":\"2025-12-12T05:00:00.000Z\",\"dateModified\":\"2025-12-12T05:00:00.000Z\",\"author\":[{\"@type\":\"Organization\",\"name\":\"Loudoun Decks Team\",\"url\":\"https://www.ldndecks.com\"}],\"publisher\":{\"@type\":\"Organization\",\"name\":\"Loudoun Decks\",\"url\":\"https://www.ldndecks.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.ldndecks.com/ldndecks-logo.webp\"}},\"description\":\"Protecting your wood framing is crucial. Learn about the chemical preservatives and butyl tapes that prevent joist decay under your composite decking.\",\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.ldndecks.com/blog/wood-preservatives-stop-rot\"},\"isAccessibleForFree\":true,\"inLanguage\":\"en-US\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\".leadParagraph\",\"h1\",\"h2\"]}}"}}],["$","div",null,{"className":"BlogContent-module__WEG1wW__heroSection","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__imgWrapper","children":[["$","$L2",null,{"src":"/images/img14.jpeg","alt":"Wood Preservatives: How to Stop Rot Before It Starts","fill":true,"className":"BlogContent-module__WEG1wW__heroImg","priority":true,"sizes":"100vw"}],["$","div",null,{"className":"BlogContent-module__WEG1wW__imgOverlay","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__containerLarge","children":[["$","$L3",null,{"href":"/blog","className":"BlogContent-module__WEG1wW__backLink","children":"← Back to News"}],["$","h1",null,{"className":"BlogContent-module__WEG1wW__title","children":"Wood Preservatives: How to Stop Rot Before It Starts"}],["$","div",null,{"className":"BlogContent-module__WEG1wW__meta","children":[["$","span",null,{"className":"BlogContent-module__WEG1wW__author","children":["By ","Loudoun Decks Team"]}],["$","span",null,{"className":"BlogContent-module__WEG1wW__divider","children":"•"}],["$","span",null,{"children":"December 12, 2025"}]]}]]}]}]]}]}],["$","div",null,{"className":"BlogContent-module__WEG1wW__contentSection","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__containerNarrow","children":["$","div",null,{"className":"BlogContent-module__WEG1wW__contentBody","children":[["$","p",null,{"className":"BlogContent-module__WEG1wW__leadParagraph","children":"Protecting your wood framing is crucial. Learn about the chemical preservatives and butyl tapes that prevent joist decay under your composite decking."}],[["$","p","0",{"children":"Many homeowners spend thousands of dollars on highly resilient luxury composite deck boards, but completely ignore the structural skeleton underneath them. Because Trex and TimberTech boards can last 50 years, the pressure-treated pine joists underneath them are often the first thing to fail. Here is how you protect them."}],["$","h2","1",{"style":{"marginTop":"40px","marginBottom":"20px","color":"#111"},"children":"The Threat of Standing Water"}],["$","p","2",{"children":"When a screw is driven through a deck board and into the joist below, it creates a microscopic puncture hole in the wood. Over thousands of rainstorms, water seeps directly into these holes. Because the space between the joists is narrow and shaded from the sun, the water never evaporates. This leads to aggressive, rapid wood rot."}],["$","h3","3",{"style":{"marginTop":"30px","marginBottom":"15px","color":"#222"},"children":"The Butyl Tape Solution"}],["$","p","4",{"children":"At Loudoun Decks, we deploy a crucial protective layer called joist tape. Before any surface boards are installed, we roll a thick layer of self-sealing butyl tape across the top ridge of every single joist and beam. "}],"$L4"],"$L5"]}]}]}],"$L6"]}],["$L7"],"$L8"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Jebrcr4Vyd2YosxlccnHN"}
4:["$","p","5",{"children":"When a screw is driven down, the butyl tape physically stretches and seals around the thread of the screw, permanently preventing water from entering the wood framing. It is an incredibly inexpensive preventative measure that adds decades to the structural life of your deck."}]
5:["$","div",null,{"className":"BlogContent-module__WEG1wW__conclusionBox","children":[["$","h3",null,{"children":"Ready to upgrade your outdoor living space?"}],["$","p",null,{"children":"Contact Loudoun Decks today for a free estimate and planning consultation."}],["$","$L3",null,{"href":"/contact","className":"BlogContent-module__WEG1wW__ctaBtn","children":"Get Started"}]]}]
