9:["$","section",null,{"className":"ServiceContentExpansion-module__6_-y9q__section","children":["$","div",null,{"className":"ServiceContentExpansion-module__6_-y9q__container","children":[["$","div","0",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Future of Outdoor Living: The Composite Revolution in NoVA"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["In the competitive Northern Virginia real estate market, homeowners are increasingly moving away from traditional wood in favor of high-performance composite decking. As a leading composite deck builder in Loudoun County, Fairfax County, and Prince William County, Loudoun Decks has mastered the art and science of these advanced materials. Our clients in Ashburn and Leesburg are looking for more than just a deck; they are looking for a permanent extension of their indoor luxury-one that doesn't require annual maintenance weekends."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["The transition to composite is driven by the desire for longevity and consistent aesthetics. Unlike natural wood, which can warp, splinter, and gray within just a few years of NoVA's humid cycles, composite materials maintain their rich color and structural integrity for decades. This 'set it and forget it' mentality is perfect for busy professionals in Arlington and the growing families in Gainesville."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["As your custom deck builder, we don't just 'install' composite; we engineer it. This includes specialized joist spacing and structural reinforcement that compensates for the unique thermal expansion and weight characteristics of high-end composite boards. When you choose a 5-Star Google Rated local expert, you are ensuring your deck remains a beautiful, safe sanctuary year after year."]}]]}],"$undefined"]}],["$","div","1",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Science of High-Performance Material: Why It Wins"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Modern composite decking is a marvel of material science. Leading brands like Trex and AZEK use a combination of recycled wood fibers and high-density polyethylene (HDPE) to create a board that is impervious to rot, insects, and moisture. In regions like Sterling and Herndon, where moisture-driven fungal growth is common on older wooden structures, composite stands as a rot-proof alternative. The 'capped' surface of the board acts as a protective shield against UV rays, ensuring that the deep browns and grays you choose during the design phase are the same colors you see 20 years later."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We prioritize material knowledge, helping you navigate the various 'tiers' of composite-from basic scalloped-back boards to ultra-premium solid-core PVC. Each has its place depending on your project's vertical architecture and budget. For instance, if you're building a deck with an integrated fire pit or outdoor kitchen, certain high-heat resistant composites are mandatory."]}],"$L14"]}],"$L15"]}],"$L16","$L17"]}]}]
a:["$","section",null,{"className":"ServiceInclusions-module__sDDdhG__section","children":["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__container","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__header","children":[["$","h2",null,{"className":"ServiceInclusions-module__sDDdhG__title","children":"The Low-Maintenance Advantage"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__description","children":"Our composite builds are designed for Northern Virginia's climate."}]]}],["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__grid","children":[["$","div","0",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Fade & Stain Protection"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Premium composite materials that withstand the intense Virginia sun and spills without fading or permanent staining."}]]}]]}],["$","div","1",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Hidden Fasteners"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"A completely smooth, splinter-free surface using industrial-grade hidden clips for a 5-Star luxury finish."}]]}]]}],["$","div","2",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Structural Integrity"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Framing systems engineered specifically to support the increased weight of composite decking in Loudoun and Fairfax."}]]}]]}],["$","div","3",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Permits & HOA Handled"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"We manage the entire permit process and HOA architectural review submissions so you don't have to."}]]}]]}],["$","div","4",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Typical Timeline: 2–4 Weeks"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Most composite deck projects are completed in 2–4 weeks from permit approval, depending on size and complexity."}]]}]]}]]}]]}]}]
