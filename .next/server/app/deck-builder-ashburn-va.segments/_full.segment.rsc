32:["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Multi-level decks are extremely popular in Ashburn, particularly on lots backing to common areas or wooded buffers. We specialize in designing decks that maximize the usable outdoor square footage of your property. Integrated outdoor kitchens, built-in seating, pergola covers, and LED lighting systems are standard requests from our Ashburn clientele."]}]
33:["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Every composite deck we build comes with a full manufacturer's warranty backed by our installation certification. This means your investment is protected  -  not just by the material's 25-year warranty, but by a builder with the credentials and local track record to honor it."]}]
34:["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Trex Platinum Partner",":"]}]," ",["Highest certification level for Trex installation in Ashburn and Northern Virginia."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["TimberTech Certified",":"]}]," ",["Certified installer for the full TimberTech Pro and AZEK product lines."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["HOA Ready",":"]}]," ",["Full CAD drawings and site plans provided for all Ashburn HOA submissions."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["5-Star Rated",":"]}]," ",["Consistently 5-Star Google Rated by Ashburn homeowners across every neighborhood."]]}]]}]
35:["$","div","3",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Screened Porches and Outdoor Living in Ashburn"}],["$","div",null,{"className":"$undefined","children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Decks are just the beginning. Many Ashburn homeowners are transforming their backyards into complete outdoor living environments. A screened porch addition to your deck allows you to enjoy the Loudoun County outdoors without the insects  -  expanding your usable living space by hundreds of square feet. We specialize in screen room additions that are structurally integrated with your new or existing deck."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Pergolas are another popular addition in Ashburn, providing shade, architectural character, and a defined outdoor room feel. We build both traditional open-rafter pergolas and louvered pergola systems that give you full weather control at the push of a button. These structures add significant curb appeal and resale value to Ashburn properties."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Our full outdoor living packages  -  deck + screened porch + pergola + outdoor kitchen  -  are among the most requested projects in Ashburn and Brambleton. These comprehensive builds typically range from $45,000 to $90,000+ and deliver a complete transformation of your property's outdoor potential."]}]]}],"$undefined"]}]
