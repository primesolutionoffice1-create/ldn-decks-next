n transforming these aging wood decks into modern, maintenance-free composite outdoor living spaces."}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le",["$Lf","$L10"],"$L11","$L12"]}]}],"$L13","$L14","$L15"],["$L16"],"$L17"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Jebrcr4Vyd2YosxlccnHN"}
