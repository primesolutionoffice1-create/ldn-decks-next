:"ServiceInclusions-module__sDDdhG__itemDesc","children":"Experienced with Leesburg town permits and the specific zoning requirements for properties within the town limits."}]]}]]}],["$","div","2",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Legacy Material Selection"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Premium cedar, Trex, and TimberTech options that complement the traditional aesthetics of Leesburg-area homes."}]]}]]}]]}]]}]}]
