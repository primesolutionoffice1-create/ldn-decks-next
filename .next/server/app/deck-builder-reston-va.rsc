33:["$","div","3",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Composite and Wood Decks for Reston Homes"}],["$","div",null,{"className":"$undefined","children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Reston homeowners value low-maintenance performance and clean aesthetics. Composite decking from Trex or TimberTech handles Reston outdoor exposure without fading, warping, or requiring seasonal work. As a Trex Platinum Partner and TimberTech Certified contractor, we provide the full premium product line with the best warranties in the industry."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["For homeowners who prefer natural wood, we work with Western Red Cedar and pressure-treated lumber where the Reston Association approves natural materials. We match every material to the home, neighborhood, and budget, always focused on long-term performance and curb appeal."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Whether you are replacing a deteriorating deck, adding a new deck to a townhome, or building a complete outdoor living space, Loudoun Decks delivers premium results at every scope. Call (571) 655-7207 for your free on-site estimate."]}]]}],"$undefined"]}]
