0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How much does a deck cost in South Riding?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"South Riding deck projects range from $18,000-$45,000. Composite decks: $32-$55/sqft installed. Most South Riding projects involve upgrading builder-grade PT decks (2005-2015 homes) to Trex or TimberTech composite. Resurfacing: $10k-$20k if frame is solid.\"}},{\"@type\":\"Question\",\"name\":\"Does South Riding HOA allow composite decks?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. South Riding HOA allows and prefers composite over wood. Architectural review required submit site plan, materials, and colors. We handle the entire ARC process with 100% approval rate.\"}}]}"}}],["$","section",null,{"style":{"background":"var(--color-dark)","color":"#fff","padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","h1",null,{"style":{"fontSize":"2.5rem","fontWeight":700,"marginBottom":"1rem"},"children":"Custom Deck Builder in South Riding, VA"}],["$","p",null,{"style":{"color":"#ccc","fontSize":"1.1rem"},"children":"Builder-grade upgrades & custom composite decks for South Riding homeowners"}],["$","div",null,{"style":{"marginTop":"1.5rem","display":"flex","gap":"1rem","flexWrap":"wrap"},"children":[["$","a",null,{"href":"tel:+15716557207","style":{"background":"var(--color-primary)","color":"#fff","padding":"0.75rem 2rem","fontWeight":600,"borderRadius":6,"textDecoration":"none"},"children":"Call (571) 655-7207"}],["$","$L2",null,{"href":"/contact","style":{"border":"2px solid #fff","color":"#fff","padding":"0.75rem 2rem","fontWeight":600,"borderRadius":6,"textDecoration":"none"},"children":"Get Free Estimate"}]]}],["$","p",null,{"style":{"marginTop":"1rem","font