11:["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Community Expertise",":"]}]," ",["Deeply familiar with HOA boards in Lansdowne, Willowsford, and Brambleton."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Permit Speed",":"]}]," ",["Established relationships with Loudoun County permitting offices for faster project starts."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Material Curation",":"]}]," ",["Selecting decking and hardware specifically tested for the high humidity of Northern Virginia."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Safety First",":"]}]," ",["Every Loudoun County build is 100% code-compliant and built to exceed safety standards."]]}]]}]
12:["$","div","2",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Loudoun County Code Advantage"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Building a deck in Loudoun County is a complex endeavor that requires strict adherence to the International Residential Code (IRC) and specific local amendments. As your local deck contractor, we handle all structural drawings and certification. We ensure that every footing is dug to the proper depth to avoid the frost line and that every support beam is sized correctly for the spans intended. This technical precision is what prevents the sagging and structural failure common in DIY or budget-grade builds."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We also handle the integrated electrical and plumbing work required for modern luxury decks. Whether you want recessed lighting for your stairs in South Riding or a natural gas line for your grill in Stone Ridge, our licensed partners ensure the work is done safely and legally. This all-in-one service is why we are considered the premier Loudoun County deck building team."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We take pride in our transparency. When we provide a quote for your project, it includes every permit fee, every drawing, and every material cost. There are no hidden surprises — just an honest, professional path to your new outdoor living space."]}]]}],"$undefined"]}]
13:["$","div","3",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Why 5-Star Google Rated Quality Matters"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["In a service industry, reputation is everything. Our 5-Star Google Rated status is not just a badge; it's a promise to the families of Loudoun County. It means that from the moment you contact us for a consultation through the final cleanup, you will receive expert communication and unmatched craftsmanship. We prioritize quality over volume, taking on a selective number of full-scale construction projects each year to ensure every site gets the attention it deserves."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Our builds feature high-end materials like Trex Transcend and premium Western Red Cedar. We utilize hidden fasteners and precision mitering to ensure that the final result is as clean as a piece of indoor furniture. For our clients in Fairfax County and Prince William County, this commitment to high-ticket quality ensures that their outdoor space remains a source of pride for 20 years or more."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We invite you to explore our gallery of local projects across NoVA. Whether you're in the heart of the tech corridor or the quiet of the Loudoun countryside, we are ready to turn your backyard into a 5-Star retreat."]}]]}],"$undefined"]}]
