"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Detailed CAD drawings and site plans provided for HOA boards in Brambleton, Willowsford, and Lansdowne."}]]}]]}],["$","div","2",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Hyper-Local Materials"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Material selections specifically curated for the unique micro-climates found across the Loudoun Valley and NoVA region."}]]}]]}]]}]]}]}]
