12:["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Trex Transcend",":"]}]," ",["Premium composite decking with the deepest wood grain embossing and the industry's best fade and stain warranty."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["TimberTech AZEK",":"]}]," ",["Full PVC decking that is completely impervious to moisture - ideal for Northern Virginia's climate extremes."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Two-Tone Designs",":"]}]," ",["Border boards, picture frames, and inlays in contrasting composite colors for custom visual character."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Hidden Fasteners",":"]}]," ",["Concealed fastener systems for a clean, fastener-free deck surface - the premium standard for 2026 builds."]]}]]}]
13:["$","div","2",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Screened Porches, Pergolas & Outdoor Kitchens: The 2026 Northern Virginia Package"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["The most popular outdoor living package in Northern Virginia for 2026 combines a custom composite deck with a screened porch addition and a pergola structure. This combination gives homeowners a versatile outdoor living environment - open-air deck space for entertaining, a screened enclosure for bug-free relaxation, and a pergola for shade and architectural character. These full-package builds are our specialty."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Outdoor kitchens are the fastest-growing add-on in the Northern Virginia market. Homeowners are integrating built-in grills, refrigerators, countertops, and bar seating directly into their deck designs - creating fully functional outdoor cooking and dining environments. These installations require careful planning around utility lines, drainage, and structural load, which is why working with an experienced local contractor like Loudoun Decks is essential."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Louvered pergola systems are another 2026 trend gaining serious momentum in Northern Virginia. These motorized roof systems allow homeowners to open or close the pergola louvers at the touch of a button - controlling shade, airflow, and rain protection. When combined with integrated LED lighting and retractable screens, a louvered pergola transforms your deck into a true four-season outdoor room."]}]]}],"$undefined"]}]
