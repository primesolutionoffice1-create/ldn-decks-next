c:["$","h2",null,{"style":"$0:rsc:props:children:0:2:props:children:props:children:1:props:style","children":"Winter Checklist (December–February)"}]
d:["$","ul",null,{"style":{"paddingLeft":"1.5rem","marginBottom":"2rem"},"children":[["$","li","0",{"style":{"marginBottom":"0.5rem","lineHeight":1.7},"children":"✅ Shovel snow with a plastic shovel (metal edges scratch composite and gouge wood)"}],["$","li","1",{"style":{"marginBottom":"0.5rem","lineHeight":1.7},"children":"✅ Do NOT use rock salt/calcium chloride on composite decks (can discolor surface)"}],["$","li","2",{"style":{"marginBottom":"0.5rem","lineHeight":1.7},"children":"✅ Use sand or kitty litter for traction instead of salt"}],["$","li","3",{"style":{"marginBottom":"0.5rem","lineHeight":1.7},"children":"✅ Keep snow from piling against the house/ledger board area"}],["$","li","4",{"style":{"marginBottom":"0.5rem","lineHeight":1.7},"children":"✅ After major snow/ice events, inspect for structural stress (sagging, shifting)"}],["$","li","5",{"style":{"marginBottom":"0.5rem","lineHeight":1.7},"children":"✅ Do NOT pressure wash in freezing temperatures water in crevices will freeze and expand"}]]}]
