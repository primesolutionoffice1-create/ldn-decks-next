dren":"Summer Checklist (May–August)"}],["$","ul",null,{"style":{"paddingLeft":"1.5rem","marginBottom":"2rem"},"children":["$L4","$L5","$L6","$L7","$L8","$L9"]}],"$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13",["$L14","$L15","$L16"],"$L17","$L18"]}]}],"$L19","$L1a"],["$L1b"],"$L1c"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Jebrcr4Vyd2YosxlccnHN"}
