55:["$","details","0",{"style":{"border":"1px solid #e5e5e5","borderRadius":8,"padding":"1.25rem","marginBottom":"0.75rem"},"children":[["$","summary",null,{"style":{"fontWeight":600,"cursor":"pointer","fontSize":"1.05rem"},"children":"Do I need a permit to build a deck in Loudoun County?"}],["$","p",null,{"style":{"marginTop":"1rem","lineHeight":1.7,"color":"#555"},"children":"Yes — any deck attached to a house, exceeding 256 sqft, or more than 16.5 inches above grade requires a building permit. This covers virtually all functional residential decks."}]]}]
