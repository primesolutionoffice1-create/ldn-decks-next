43:["$","div",null,{"style":{"display":"grid","gap":"1rem","marginBottom":"2rem"},"children":[["$","div","1",{"style":{"background":"#f9f9f9","borderRadius":8,"padding":"1.5rem","borderLeft":"4px solid var(--color-primary)"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.25rem"},"children":["Inspection #","1",": ","Footing Inspection"]}],["$","p",null,{"style":{"fontSize":"0.85rem","color":"#666","marginBottom":"0.75rem"},"children":"After holes are dug, before concrete is poured"}],["$","p",null,{"style":{"lineHeight":1.7,"margin":0},"children":"Inspector verifies footing hole depth (24\" minimum below grade for frost line), diameter, and location match the approved plans. Soil conditions are checked — if the inspector finds fill dirt or unstable soil, deeper footings or helical piers may be required."}]]}],["$","div","2",{"style":{"background":"#f9f9f9","borderRadius":8,"padding":"1.5rem","borderLeft":"4px solid var(--color-primary)"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.25rem"},"children":["Inspection #","2",": ","Framing Inspection"]}],["$","p",null,{"style":{"fontSize":"0.85rem","color":"#666","marginBottom":"0.75rem"},"children":"After framing is complete, before decking boards are installed"}],["$","p",null,{"style":{"lineHeight":1.7,"margin":0},"children":"Inspector checks ledger board attachment (proper flashing, lag bolts or through-bolts), joist hangers, beam-to-post connections, lateral bracing, and that all framing lumber matches the approved plan specifications. This is the most detailed inspection."}]]}],["$","div","3",{"style":{"background":"#f9f9f9","borderRadius":8,"padding":"1.5rem","borderLeft":"4px solid var(--color-primary)"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.25rem"},"children":["Inspection #","3",": ","Final Inspection"]}],["$","p",null,{"style":{"fontSize":"0.85rem","color":"#666","marginBottom":"0.75rem"},"children":"After all work is complete"}],["$","p",null,{"style":{"lineHeight":1.7,"margin":0},"children":"Inspector verifies railing height and spacing (4\" max baluster gap), stair dimensions (consistent rise/run, proper handrail), decking fastener pattern, and overall structural integrity. Once passed, the county issues a Certificate of Completion."}]]}]]}]
