40:["$","p",null,{"style":"$1e:props:children:props:children:2:props:style","children":[["$","strong",null,{"children":"Pro tip:"}]," Start your design consultation 8–10 weeks before your desired build start date. This gives us time to design, submit to your HOA, receive approval, submit to the county, and have the permit in hand before the build crew arrives."]}]
