12L10 17L20 7","stroke":"white","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round"}]}]}],["$","div",null,{"className":"ProcessSteps-module__7tzpxa__stepLabel","children":"Step 2"}],["$","h3",null,{"className":"ProcessSteps-module__7tzpxa__stepTitle","children":"On-Site Visit and Planning"}]]}],["$","div",null,{"className":"ProcessSteps-module__7tzpxa__textArea","children":["$","p",null,{"children":"If you decide to move forward, we schedule an on-site visit to review the space in more detail. This allows us to take measurements, discuss layout options, and better understand how the outdoor area will be used. Planning at this stage helps ensure the project is designed around the home, the property, and the homeowner’s needs."}]}]]}]}]}],["$","div","2",{"className":"ProcessSteps-module__7tzpxa__stepRow","style":{"backgroundColor":"#fcfaf8"},"children":["$","div",null,{"className":"ProcessSteps-module__7tzpxa__container","children":["$","div",null,{"className":"ProcessSteps-module__7tzpxa__stepContent","children":[["$","div",null,{"className":"ProcessSteps-module__7tzpxa__iconArea","children":[["$","div",null,{"className":"ProcessSteps-module__7tzpxa__iconCircle","children":["$","svg",null,{"width":"40","height":"40","viewBox":"0 0 24 24","fill":"none","xmlns":"http://www.w3.org/2000/svg","children":["$","path",null,{"d":"M5 12L10 17L20 7","stroke":"white","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round"}]}]}],["$","div",null,{"className":"ProcessSteps-module__7tzpxa__stepLabel","children":"Step 3"}],["$","h3",null,{"className":"ProcessSteps-module__7tzpxa__stepTitle","children":"Project Review and Next Steps"}]]}],["$","div",null,{"className":"ProcessSteps-module__7tzpxa__textArea","children":["$","p",null,{"children":"After reviewing the details of the project, we outline the next steps so homeowners know what to expect before construction begins. This stage focuses on clarity helping homeowners understand the scope of work and how the project will move forward."}]}]]}]}]}],["$","div","3",{"className":"ProcessSteps-module__7tzpxa__stepRow","style":{"backgroundColor":"#ffffff"},"children":"$L34"}]]}]
