14:["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Ledger Board Failures",":"]}]," ",["The #1 cause of deck collapses; we ensure your deck is physically bolted to the house's rim joist."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Wood Rot",":"]}]," ",["Fungal decay that eats through structural timber; we replace affected areas with ACQ-treated wood."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Corroded Fasteners",":"]}]," ",["In older decks, galvanized nails can rust away; we upgrade to stainless steel or ceramic-coated screws."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Unstable Foundations",":"]}]," ",["Shifting concrete piers can cause a deck to sag; we provide leveling and re-shimming services."]]}]]}]
15:["$","div","2",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Resurfacing vs. Full Replacement: The Cost-Effective Path"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["One of our most popular services for homeowners in Loudoun County and Arlington is 'Deck Resurfacing.' This process is ideal if your deck's 'skeleton'-the posts, beams, and joists-is still structurally sound but the top boards are splintering or warped. By removing the surface material and replacing it with brand-new wood or low-maintenance composite like Trex, you can get a 'new deck' look for a fraction of the cost of a full knockdown and rebuild."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["During a resurfacing project, we also take the opportunity to reinforce the existing structure. We add 'joist hangers' where they might be missing and double-up on beams to bring the deck in line with modern safety standards. This hybrid approach is extremely popular in Great Falls and Mclean, where large existing footprints make full replacements prohibitively expensive or complicated with modern zoning setbacks."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Whether you need a simple board swap or a massive structural overhaul, we approach every repair project with the same level of care and precision as our new $50k+ custom builds."]}]]}],"$undefined"]}]
16:["$","div","3",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Loudoun Decks Restoration Protocol"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Our deck repair process begins with a comprehensive safety audit. We don't just quote you for what you asked for; we tell you what you *need* to be safe. Our technicians crawl into the substructure to check for rot and fastener integrity. In areas like Gainesville and Manassas, where older neighborhoods often feature decks built 20+ years ago, these audits are literally lifesavers."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Once we identify the scope, we source materials that match your existing deck as closely as possible. We specialize in working with aged cedar, pressure-treated pine, and all major composite brands. Our goal is for the repair to be as invisible as possible, maintaining the cohesive look of your outdoor space. We also provide advice on staining and sealing to ensure the new wood integrates perfectly with the old."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We are proud to be the premier deck company near you for restorations, helping Northern Virginia homeowners protect their families and their real estate investments."]}]]}],"$undefined"]}]
