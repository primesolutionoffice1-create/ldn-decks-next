1a:T64b,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is deck resurfacing?","acceptedAnswer":{"@type":"Answer","text":"Deck resurfacing means removing the old deck boards (and usually railings) but keeping the existing frame joists, beams, posts, and footings. New composite deck boards and railings are installed on the existing structure. This saves 40-60% vs a full rebuild because you're not paying for new framing, footings, or demolition of a sound structure."}},{"@type":"Question","name":"When should I resurface vs replace my deck?","acceptedAnswer":{"@type":"Answer","text":"Resurface if: joists are solid (poke test), posts are straight and not rotting, footings aren't shifting, and ledger board is secure. Replace if: joists are soft/rotting, posts are leaning, footings have heaved, deck feels bouncy, or ledger is pulling away from house. We offer free inspections to determine which you need."}},{"@type":"Question","name":"How much does deck resurfacing cost vs replacement?","acceptedAnswer":{"@type":"Answer","text":"In Northern Virginia: resurfacing costs $10,000-$25,000 for a typical 300-400 sqft deck. Full replacement costs $20,000-$50,000 for the same size. Resurfacing saves 40-60% when the existing frame is structurally sound."}},{"@type":"Question","name":"How long does resurfacing take vs replacement?","acceptedAnswer":{"@type":"Answer","text":"Resurfacing: 1-2 weeks (no footing or framing work needed). Full replacement: 2-4 weeks (includes demolition, new footings, framing, then decking). Permit timeline is the same for both."}}]}c:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],["$","section",null,{"style":{"background":"var(--color-dark)","color":"#fff","padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","h1",null,{"style":{"fontSize":"2.5rem","fontWeight":700,"marginBottom":"1rem"},"children":"Deck Resurfacing vs Replacement"}],["$","p",null,{"style":{"color":"#ccc","fontSize":"1.1rem"},"children":"Save 40-60% by resurfacing or invest in a full rebuild when it's the smarter choice"}]]}]}],["$","section",null,{"style":{"background":"#fff3e0","borderLeft":"4px solid var(--color-primary)","padding":"1.5rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","p",null,{"style":{"fontWeight":600,"marginBottom":"0.5rem"},"children":"Quick Answer:"}],["$","p",null,{"children":[["$","strong",null,{"children":"Resurface"}]," ($10k–$25k) if your frame is solid saves 40-60%. ",["$","strong",null,{"children":"Replace"}]," ($20k–$50k) if joists are rotting, posts leaning, or deck feels bouncy. ",["$","strong",null,{"children":"Not sure?"}]," We offer free inspections we'll tell you honestly which makes sense."]}]]}]}],["$","article",null,{"style":{"padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","div",null,{"style":{"position":"relative","width":"100%","height":"400px","borderRadius":"12px","overflow":"hidden","marginBottom":"2rem"},"children":["$","$L1b",null,{"src":"/images/img26.jpeg","alt":"Deck resurfacing process in Northern Virginia","fill":true,"style":{"objectFit":"cover"},"sizes":"(max-width: 900px) 100vw, 900px","priority":true}]}],["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem"},"children":"Standard vs. Premium Resurfacing Option"}],["$","div",null,{"style":{"overflowX":"auto","marginBottom":"2rem"},"children":["$","table",null,{"style":{"width":"100%","borderCollapse":"collapse","fontSize":"0.9rem"},"children":[["$","thead",null,{"children":["$","tr",null,{"style":{"background":"#f5f5f5"},"children":[["$","th","Factor",{"style":{"padding":"0.75rem","textAlign":"left","borderBottom":"2px solid #ddd"},"children":"Factor"}],"$L1c","$L1d"]}]}]