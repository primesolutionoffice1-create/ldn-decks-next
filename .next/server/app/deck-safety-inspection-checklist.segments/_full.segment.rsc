1a:T544,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How do I know if my deck is safe?","acceptedAnswer":{"@type":"Answer","text":"Inspect these 5 critical areas: 1) Ledger board look for gaps between deck and house, rust stains, or water damage on the wall below. 2) Support posts check bases for rot (poke test with screwdriver). 3) Joists look under the deck for sagging, cracks, or soft wood. 4) Railings push-test every post; they should not wobble. 5) Deck surface check for soft spots, severe splintering, or boards that flex underfoot."}},{"@type":"Question","name":"How often should I inspect my deck?","acceptedAnswer":{"@type":"Answer","text":"Inspect twice yearly spring (after winter damage) and fall (before winter). Wood decks over 10 years old should get a professional structural inspection annually. Composite decks need less frequent inspection but should still be checked yearly for hardware and connection points."}},{"@type":"Question","name":"What is the most dangerous deck failure?","acceptedAnswer":{"@type":"Answer","text":"Ledger board failure where the deck detaches from the house. This causes the most injuries and fatalities of any deck failure type. It happens when the ledger attachment corrodes, rots, or was improperly installed. Check the ledger connection annually."}}]}c:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],["$","section",null,{"style":{"background":"var(--color-dark)","color":"#fff","padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","div",null,{"style":{"position":"relative","width":"100%","height":"400px","borderRadius":"12px","overflow":"hidden","marginBottom":"2rem"},"children":["$","$L1b",null,{"src":"/images/img61.jpeg","alt":"Professional deck safety inspection in Northern Virginia","fill":true,"style":{"objectFit":"cover"},"sizes":"(max-width: 900px) 100vw, 900px","priority":true}]}],["$","h1",null,{"style":{"fontSize":"2.5rem","fontWeight":700,"marginBottom":"1rem"},"children":"Deck Safety Inspection Checklist"}],["$","p",null,{"style":{"color":"#ccc","fontSize":"1.1rem"},"children":"15-point checklist to determine if your deck is safe or if it needs repair or replacement"}]]}]}],["$","section",null,{"style":{"background":"#ffebee","borderLeft":"4px solid #c62828","padding":"1.5rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","p",null,{"style":{"fontWeight":600,"color":"#c62828","marginBottom":"0.5rem"},"children":"Safety Warning:"}],["$","p",null,{"children":["Deck collapses injure thousands of people annually in the US. The #1 cause: ",["$","strong",null,{"children":"ledger board failure"}]," (deck detaching from the house). If your deck is over 15 years old, has never been inspected, or shows any of the warning signs below get a professional inspection before your next gathering."]}]]}]}],["$","article",null,{"style":{"padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[[["$","div","Ledger Board (CRITICAL)",{"style":{"marginBottom":"2.5rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.4rem","fontWeight":700,"marginBottom":"1rem","borderBottom":"2px solid var(--color-primary)","paddingBottom":"0.5rem"},"children":"Ledger Board (CRITICAL)"}],[["$","div","0",{"style":{"display":"flex","alignItems":"flex-start","gap":"0.75rem","marginBottom":"0.75rem"},"children":[["$","span",null,{"style":{"fontSize":"1.2rem","lineHeight":1.4},"children":"☐"}],["$","p",null,{"style":{"lineHeight":1.6},"children":"No gap between deck frame and house wall"}]]}],["$","div","1",{"style":{"display":"flex","alignItems":"flex-start","gap":"0.75rem","marginBottom":"0.75rem"},"children":[["$","span",null,{"style":{"fontSize":"1.2rem","lineHeight":1.4},"children":"☐"}],["$","p