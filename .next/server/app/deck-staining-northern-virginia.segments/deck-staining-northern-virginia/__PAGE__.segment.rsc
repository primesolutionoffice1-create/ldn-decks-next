4:["$","ol",null,{"style":{"paddingLeft":"1.5rem","marginBottom":"2rem"},"children":[["$","li","0",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":["Step ",1,": ","Inspection"]}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"We check every board, joist connection, and fastener. If structural issues are found, we address them before staining (no point staining a deck that needs repair)."}]]}],["$","li","1",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":["Step ",2,": ","Power washing"]}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"Professional-grade pressure washing removes dirt, mildew, old stain, and gray oxidation. We use the right PSI — too much damages wood fibers."}]]}],["$","li","2",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":["Step ",3,": ","Sanding (if needed)"]}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"Rough or splintering boards are sanded smooth. This also opens the wood grain to accept stain more evenly."}]]}],["$","li","3",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":["Step ",4,": ","Brightener application"]}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"Wood brightener restores the natural color and opens pores for maximum stain penetration. This step is what separates a professional job from DIY."}]]}],["$","li","4",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":["Step ",5,": ","Stain application"]}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"We apply premium exterior stain (typically 2 coats) using professional sprayers and back-brushing for even coverage. We use UV-resistant, waterproof formulations rated for Virginia climate."}]]}]]}]
