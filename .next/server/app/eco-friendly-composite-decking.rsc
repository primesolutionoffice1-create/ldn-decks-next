1a:T530,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is composite decking eco-friendly?","acceptedAnswer":{"@type":"Answer","text":"Yes. Trex composite decking is made from 95% recycled materials reclaimed wood fibers and recycled plastic film (grocery bags, newspaper sleeves). Trex alone diverts 500+ million pounds of plastic and wood from landfills each year. And because composite lasts 25-50 years vs 10-15 for wood, fewer decks end up in landfills over time."}},{"@type":"Question","name":"Is composite decking better for the environment than wood?","acceptedAnswer":{"@type":"Answer","text":"Yes, in several ways: composite uses recycled materials instead of harvesting new timber, lasts 2-3x longer (fewer replacements), requires no chemical stains or sealants (no toxic runoff), and is itself recyclable at end of life. Pressure-treated wood uses chromated copper arsenate and must be disposed of as hazardous waste."}},{"@type":"Question","name":"Can composite decking be recycled?","acceptedAnswer":{"@type":"Answer","text":"Some composite decking brands can be recycled at end of life. Trex operates a recycling program for its own products. Additionally, unused scraps from installation can be recycled. Check with the specific manufacturer for their recycling program."}}]}c:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],["$","section",null,{"style":{"background":"var(--color-dark)","color":"#fff","padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","div",null,{"style":{"position":"relative","width":"100%","height":"400px","borderRadius":"12px","overflow":"hidden","marginBottom":"2rem"},"children":["$","$L1b",null,{"src":"/images/img44.jpeg","alt":"Eco-friendly composite decking project by LDN Decks","fill":true,"style":{"objectFit":"cover"},"sizes":"(max-width: 900px) 100vw, 900px","priority":true}]}],["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem"},"children":"Sustainable Outdoor Living Modern Composite Decking"}],["$","p",null,{"style":{"color":"#ccc","fontSize":"1.1rem"},"children":"Build a beautiful deck and reduce your environmental footprint 95% recycled materials"}]]}]}],["$","section",null,{"style":{"background":"#e8f5e9","borderLeft":"4px solid #2e7d32","padding":"1.5rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","p",null,{"style":{"fontWeight":600,"marginBottom":"0.5rem","color":"#2e7d32"},"children":"The Green Choice:"}],["$","p",null,{"children":["Trex composite decking is made from ",["$","strong",null,{"children":"95% recycled materials"}]," recycled plastic bags and reclaimed wood. Every 500 sqft Trex deck diverts ~140,000 plastic bags from landfills. Zero-maintenance = no chemical stains polluting your soil and waterways."]}]]}]}],["$","article",null,{"style":{"padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem"},"children":"Environmental Impact: Composite vs Wood"}],["$","div",null,{"style":{"overflowX":"auto","marginBottom":"2rem"},"children":["$","table",null,{"style":{"width":"100%","borderCollapse":"collapse","fontSize":"0.9rem"},"children":[["$","thead",null,{"children":["$","tr",null,{"style":{"background":"#f5f5f5"},"children":[["$","th","Factor",{"style":{"padding":"0.75rem","textAlign":"left","borderBottom":"2px solid #ddd"},"children":"Factor"}],["$","th","Pressure-Treated Wood",{"style":"$c:props:children:0:3:props:children:props:children:1:props:children:props:children:0:props:children:props:children:0:props:style","children":"Pressure-Treated Wood"}],["$","th","Trex Composite",{"style":"$c:props:children:0:3:props:children:props:children:1:props:c