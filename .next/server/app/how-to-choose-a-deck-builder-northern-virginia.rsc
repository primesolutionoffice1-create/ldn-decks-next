1a:T577,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How do I verify a deck builder's license in Virginia?","acceptedAnswer":{"@type":"Answer","text":"Visit the Virginia DPOR License Lookup at https://dfrnet.dpor.virginia.gov/. Search by company name or license number. Every contractor doing work over $1,000 in Virginia must have a Class A, B, or C contractor license."}},{"@type":"Question","name":"What should I look for in a deck builder's estimate?","acceptedAnswer":{"@type":"Answer","text":"An itemized materials list (brand, model, color), separate labor cost, permit fees, dumpster/cleanup, project timeline, warranty terms in writing, and the contractor's Virginia license number."}},{"@type":"Question","name":"Should I get multiple deck quotes?","acceptedAnswer":{"@type":"Answer","text":"Yes — get 2-3 quotes from licensed contractors. Compare not just price, but scope, materials, warranty, timeline, and permit handling. The cheapest quote often excludes permits, cleanup, or uses inferior materials."}},{"@type":"Question","name":"What are red flags when hiring a deck builder?","acceptedAnswer":{"@type":"Answer","text":"No Virginia contractor license, cash-only payment demands, no written warranty, no permit mentioned, can't provide recent local references, pressure to sign immediately, price significantly below all other quotes."}}]}c:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],["$","section",null,{"style":{"background":"var(--color-dark)","color":"#fff","padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","h1",null,{"style":{"fontSize":"2.5rem","fontWeight":700,"marginBottom":"1rem"},"children":"How to Choose a Deck Builder in Northern Virginia"}],["$","p",null,{"style":{"color":"#ccc","fontSize":"1.1rem"},"children":"10 questions to ask, 5 red flags to avoid, and how to verify credentials"}]]}]}],["$","article",null,{"style":{"padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","div",null,{"style":{"position":"relative","width":"100%","height":"400px","borderRadius":"12px","overflow":"hidden","marginBottom":"2rem"},"children":["$","$L1b",null,{"src":"/images/img25.jpeg","alt":"Professional deck construction detail showing quality craftsmanship","fill":true,"style":{"objectFit":"cover"},"sizes":"(max-width: 900px) 100vw, 900px","priority":true}]}],["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem"},"children":"10 Questions to Ask Before You Hire"}],["$","ol",null,{"style":{"paddingLeft":"1.5rem","marginBottom":"2rem"},"children":[["$","li","0",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Are you licensed in Virginia?"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"Virginia requires a DPOR contractor license for any work over $1,000. Ask for their license number and verify it at dpor.virginia.gov."}]]}],["$","li","1",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Do you carry liability insurance and workers' comp?"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"Without it, you're personally liable if a worker is injured on your property. Ask for a certificate of insurance."}]]}],["$","li","2",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Will you pull the building permit?"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"A quality builder handles permits and inspections. If they suggest skipping the permit, walk away."}]]}],["$","li","3",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Do you handle HOA submissions?"}],"$L1c","$L1d"]}],"