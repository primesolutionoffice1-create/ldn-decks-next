4:["$","div",null,{"className":"LocationPage-module__MelPIa__container","children":["$","div",null,{"className":"LocationPage-module__MelPIa__permitContent","children":["$","div",null,{"className":"LocationPage-module__MelPIa__permitText","children":[["$","h2",null,{"children":"Permits & Local Requirements in Fairfax County"}],["$","p",null,{"children":"Many deck and outdoor construction projects in Fairfax County require permits and must follow local building codes and inspection rules. Loudoun Decks helps simplify this process by coordinating directly with the county."}],["$","ul",null,{"className":"LocationPage-module__MelPIa__permitList","children":[["$","li",null,{"children":"Reviewing your project requirements"}],["$","li",null,{"children":"Preparing basic plans for permitting"}],["$","li",null,{"children":"Coordinating with the county for necessary approvals"}],["$","li",null,{"children":"Building according to local standards and guidelines"}]]}],["$","p",null,{"className":"LocationPage-module__MelPIa__permitFooter","children":"This means you don't have to worry about paperwork or code compliance - we include this as part of a smooth, start-to-finish experience."}]]}]}]}]
