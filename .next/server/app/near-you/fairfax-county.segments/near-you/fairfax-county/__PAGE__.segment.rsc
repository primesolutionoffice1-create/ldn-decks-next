6:["$","article",null,{"style":{"padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem"},"children":"Why Fairfax County Homeowners Trust LDN Decks"}],["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":"Fairfax County is the most populous county in Virginia with over 1.1 million residents and median home values exceeding $650,000. The county's established neighborhoods — from Vienna and McLean to Burke and Springfield — represent decades of homeownership, and many properties are now due for outdoor living upgrades as original decks reach the end of their lifespan."}],["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":["LDN Decks brings ",["$","strong",null,{"children":"Trex Platinum Partner"}]," and ",["$","strong",null,{"children":"TimberTech Certified Installer"}]," expertise to every Fairfax County project. We understand the county's detailed building code requirements, HOA architectural review processes, and the high standards Fairfax homeowners expect."]}],["$","h3",null,{"style":{"fontSize":"1.3rem","fontWeight":600,"margin":"2rem 0 1rem"},"children":"Fairfax County Building Permits & Codes"}],["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":["Fairfax County requires building permits for all attached decks and any deck over 200 square feet. Applications are submitted through the ",["$","strong",null,{"children":"FIDO online system"}]," (Fairfax Inspections Database Online). Processing time is ",["$","strong",null,{"children":"3-6 weeks"}]," — longer than Loudoun or Prince William counties. Three inspections required: footing, framing, final."]}],["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":["LDN Decks handles the ",["$","strong",null,{"children":"entire Fairfax County permit process"}]," including structural drawings, FIDO submission, and inspector coordination. We build to exceed Fairfax County's typical deck detail specifications and maintain a ",["$","strong",null,{"children":"100% permit approval rate"}],"."]}],["$","h3",null,{"style":{"fontSize":"1.3rem","fontWeight":600,"margin":"2rem 0 1rem"},"children":"Deck Cost in Fairfax County (2026)"}],["$","div",null,{"style":{"overflowX":"auto","marginBottom":"2rem"},"children":["$","table",null,{"style":{"width":"100%","borderCollapse":"collapse","fontSize":"0.9rem"},"children":[["$","thead",null,{"children":["$","tr",null,{"style":{"background":"#f5f5f5"},"children":[["$","th",null,{"style":{"padding":"0.75rem","textAlign":"left","borderBottom":"2px solid #ddd"},"children":"Project"}],["$","th",null,{"style":{"padding":"0.75rem","textAlign":"left","borderBottom":"2px solid #ddd"},"children":"Cost Range"}],["$","th",null,{"style":{"padding":"0.75rem","textAlign":"left","borderBottom":"2px solid #ddd"},"children":"Timeline"}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"style":{"background":"#fff"},"children":[["$","td","0",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400},"children":"300 sqft Composite Deck"}],["$","td","1",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600},"children":"$$16,000 – $32,000"}],["$","td","2",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400},"children":"1-2 weeks"}]]}],["$","tr","1",{"style":{"background":"#fafafa"},"children":[["$","td","0",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400},"children":"500 sqft Multi-Level Deck"}],["$","td","1",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":600},"children":"$$32,000 – $55,000"}],["$","td","2",{"style":{"padding":"0.75rem","borderBottom":"1px solid #eee","fontWeight":400},"children":"2-4 weeks"}]]}],["$","tr","2",{"style":{"background":"#fff"},"children":[["$","td","0",{"style":{"padding":"0