1b:["$","section","cost",{"id":"cost","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"1. How Much Does a Deck Cost?"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Composite decks in Northern Virginia cost $30–$75/sqft installed. Pressure-treated wood: $18–$35/sqft. A typical 300–500 sqft project runs $15,000–$45,000. Northern Virginia prices are 25–35% above the state average due to higher labor, stricter codes, and HOA requirements."}],["$","$L17",null,{"href":"/how-much-does-a-deck-cost-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Full pricing guide with tables →"}],false]}]
1c:["$","section","materials",{"id":"materials","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"2. Choosing the Right Material"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Trex Transcend is the best overall choice for most NoVA homeowners best balance of durability, appearance, and price ($45–$65/sqft). TimberTech AZEK is the premium pick ($50–$75/sqft, 50-year warranty). Trex Enhance is the budget option ($30–$50/sqft). Wood costs less upfront but more over 15 years when you add maintenance."}],["$","$L17",null,{"href":"/trex-vs-timbertech-vs-azek","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Trex vs TimberTech vs AZEK comparison →"}],false]}]
1d:["$","section","composite-vs-wood",{"id":"composite-vs-wood","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"3. Composite vs Wood"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Over 15 years, composite is actually cheaper than wood. Wood needs $300–$800/year in staining and repairs. Composite needs zero maintenance. Wood lasts 10–15 years; composite lasts 25–50 years. Composite recoups 65–80% at resale vs 50–65% for wood. For Virginia's freeze-thaw climate, composite is the clear winner."}],["$","$L17",null,{"href":"/composite-deck-vs-wood-deck-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Full composite vs wood comparison →"}],false]}]
1e:["$","section","permits",{"id":"permits","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"4. Permits in Northern Virginia"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Every deck attached to a house or over 30 inches above grade needs a building permit. Loudoun County: 10–15 business days. Fairfax County: 3–6 weeks. Prince William: 2–4 weeks. Three inspections required: footings, framing, final. Cost: $200–$800. A quality builder handles all permits for you."}],["$","$L17",null,{"href":"/deck-permit-fairfax-county-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Fairfax County permit guide →"}],false]}]
1f:["$","section","hoa",{"id":"hoa","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"5. HOA Approval"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Over 80% of NoVA homes are in HOA communities requiring architectural review before deck construction. Submit: site plan, materials list, color samples, railing details. Timeline: 2–4 weeks. Common restrictions: material type, colors, railing profile, setbacks. We handle all HOA submissions with a 100% approval rate."}],["$","$L17",null,{"href":"/hoa-deck-rules-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Complete HOA guide →"}],false]}]
20:["$","section","size",{"id":"size","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"6. What Size Deck to Build"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Couples: 150–200 sqft. Families of 4: 300–400 sqft. Entertainers: 500+ sqft. Average NoVA deck: 300–400 sqft. Don't exceed 20–25% of your backyard area. Allow 12×12 ft minimum for a 6-person dining table with walking room."}],["$","$L17",null,{"href":"/what-size-deck-should-i-build","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Deck size guide with tables →"}],false]}]
21:["$","section","timeline",{"id":"timeline","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"7. How Long Does It Take?"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Construction: 2–4 weeks for most decks. Full timeline including consultation, design, permits, and construction: 6–12 weeks. The biggest variable is permits Fairfax County can take 3–6 weeks alone. Start the process 2–3 months before your desired completion date."}],["$","$L17",null,{"href":"/how-long-to-build-a-deck-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Full timeline breakdown →"}],false]}]
22:["$","section","best-time",{"id":"best-time","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"8. Best Time to Build"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"February–April for best pricing and availability. May–August is peak season with 4–6 week waits. September–November is the second-best window. Winter builds get 10–15% better pricing due to lower demand."}],["$","$L17",null,{"href":"/best-time-to-build-a-deck-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Month-by-month building calendar →"}],["$","div",null,{"style":{"background":"var(--color-primary)","color":"#fff","borderRadius":8,"padding":"2rem","marginTop":"2rem","textAlign":"center"},"children":[["$","h3",null,{"style":{"fontSize":"1.3rem","fontWeight":700,"marginBottom":"0.5rem"},"children":"Ready to Start Your Project?"}],["$","p",null,{"style":{"marginBottom":"1rem","opacity":0.9},"children":"Free on-site consultation · Detailed estimate in 48 hours · We handle permits & HOA"}],["$","div",null,{"style":{"display":"flex","gap":"1rem","justifyContent":"center","flexWrap":"wrap"},"children":[["$","a",null,{"href":"tel:+15716557207","style":{"background":"#fff","color":"var(--color-primary)","padding":"0.75rem 2rem","fontWeight":600,"borderRadius":6,"textDecoration":"none"},"children":"Call (571) 655-7207"}],["$","$L17",null,{"href":"/contact","style":{"border":"2px solid #fff","color":"#fff","padding":"0.75rem 2rem","fontWeight":600,"borderRadius":6,"textDecoration":"none"},"children":"Get Free Estimate"}]]}]]}]]}]
23:["$","section","railings",{"id":"railings","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"9. Railing Options"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Composite ($40–$70/ft): most popular, zero maintenance. Aluminum ($35–$60/ft): clean modern look. Cable rail ($60–$100/ft): best view, modern. Glass ($80–$150/ft): premium, unobstructed. Check HOA guidelines some restrict cable and glass railings."}],["$","$L17",null,{"href":"/deck-railing-options-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"All railing options compared →"}],false]}]
24:["$","section","lighting",{"id":"lighting","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"10. Deck Lighting"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Post cap lights + stair risers = essential ($500–$1,200). Add under-rail LED strips for the popular package ($1,500–$3,000). Premium with recessed + smart controls: $3,000–$5,000+. Include lighting in the initial build 30–50% cheaper than retrofitting."}],["$","$L17",null,{"href":"/deck-lighting-ideas-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Lighting options and costs →"}],false]}]
25:["$","section","choose-builder",{"id":"choose-builder","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"11. Choosing a Contractor"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"10 questions to ask: License? Insurance? Permits? HOA? Materials? References? Warranty? Estimate details? Timeline? Change orders? Red flags: no license, cash-only, no written warranty, suggests skipping permits, price far below others."}],["$","$L17",null,{"href":"/how-to-choose-a-deck-builder-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"10 questions + 5 red flags →"}],false]}]
26:["$","section","roi",{"id":"roi","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"12. Does a Deck Add Value?"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Composite deck ROI: 65–80% at resale. Screened porch: 70–85%. Wood deck: 50–65%. In NoVA's competitive market, homes with finished outdoor spaces sell 3–5 days faster. A $35,000 Trex deck can add $21,000–$28,000 to your home value."}],["$","$L17",null,{"href":"/does-a-deck-add-value-to-your-home","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Full ROI data →"}],false]}]
27:["$","section","maintenance",{"id":"maintenance","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"13. Maintenance"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Composite: wash 1–2x/year with soap and water. That's it. Wood: stain/seal every 1–2 years ($600–$2,000), sand, replace rotted boards. Virginia's freeze-thaw (50–80 cycles/winter) and humidity (70–90% in summer) make maintenance critical for wood and trivial for composite."}],["$","$L17",null,{"href":"/deck-maintenance-checklist-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Seasonal maintenance checklist →"}],false]}]
28:["$","section","screened-porch",{"id":"screened-porch","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"14. Screened Porch Option"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Screened porches cost $25,000–$70,000+ but extend usable season from 5 months to 9–10 months. EZE-Breeze windows convert to a 3-season room. ROI at resale: 70–85%. Many clients combine an open deck with a screened porch for the best of both worlds."}],["$","$L17",null,{"href":"/screened-porch-cost-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Screened porch cost guide →"}],false]}]
29:["$","section","financing",{"id":"financing","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"15. Financing Options"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Finance your deck with $0 down and 12–60 month terms. Typical payments for a $30,000 deck: ~$525/month over 60 months. Building now locks in today's prices material costs rise 5–8% annually. Your deck adds home equity from day one."}],["$","$L17",null,{"href":"/deck-financing-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Financing options and payments →"}],false]}]
