3:["$","section","cost",{"id":"cost","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"1. How Much Does a Deck Cost?"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Composite decks in Northern Virginia cost $30–$75/sqft installed. Pressure-treated wood: $18–$35/sqft. A typical 300–500 sqft project runs $15,000–$45,000. Northern Virginia prices are 25–35% above the state average due to higher labor, stricter codes, and HOA requirements."}],["$","$L17",null,{"href":"/how-much-does-a-deck-cost-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Full pricing guide with tables →"}],false]}]
4:["$","section","materials",{"id":"materials","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"2. Choosing the Right Material"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Trex Transcend is the best overall choice for most NoVA homeowners best balance of durability, appearance, and price ($45–$65/sqft). TimberTech AZEK is the premium pick ($50–$75/sqft, 50-year warranty). Trex Enhance is the budget option ($30–$50/sqft). Wood costs less upfront but more over 15 years when you add maintenance."}],["$","$L17",null,{"href":"/trex-vs-timbertech-vs-azek","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Trex vs TimberTech vs AZEK comparison →"}],false]}]
5:["$","section","composite-vs-wood",{"id":"composite-vs-wood","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"3. Composite vs Wood"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Over 15 years, composite is actually cheaper than wood. Wood needs $300–$800/year in staining and repairs. Composite needs zero maintenance. Wood lasts 10–15 years; composite lasts 25–50 years. Composite recoups 65–80% at resale vs 50–65% for wood. For Virginia's freeze-thaw climate, composite is the clear winner."}],["$","$L17",null,{"href":"/composite-deck-vs-wood-deck-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Full composite vs wood comparison →"}],false]}]
6:["$","section","permits",{"id":"permits","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"4. Permits in Northern Virginia"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Every deck attached to a house or over 30 inches above grade needs a building permit. Loudoun County: 10–15 business days. Fairfax County: 3–6 weeks. Prince William: 2–4 weeks. Three inspections required: footings, framing, final. Cost: $200–$800. A quality builder handles all permits for you."}],["$","$L17",null,{"href":"/deck-permit-fairfax-county-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Fairfax County permit guide →"}],false]}]
7:["$","section","hoa",{"id":"hoa","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"5. HOA Approval"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Over 80% of NoVA homes are in HOA communities requiring architectural review before deck construction. Submit: site plan, materials list, color samples, railing details. Timeline: 2–4 weeks. Common restrictions: material type, colors, railing profile, setbacks. We handle all HOA submissions with a 100% approval rate."}],["$","$L17",null,{"href":"/hoa-deck-rules-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Complete HOA guide →"}],false]}]
8:["$","section","size",{"id":"size","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"6. What Size Deck to Build"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Couples: 150–200 sqft. Families of 4: 300–400 sqft. Entertainers: 500+ sqft. Average NoVA deck: 300–400 sqft. Don't exceed 20–25% of your backyard area. Allow 12×12 ft minimum for a 6-person dining table with walking room."}],["$","$L17",null,{"href":"/what-size-deck-should-i-build","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Deck size guide with tables →"}],false]}]
9:["$","section","timeline",{"id":"timeline","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"7. How Long Does It Take?"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Construction: 2–4 weeks for most decks. Full timeline including consultation, design, permits, and construction: 6–12 weeks. The biggest variable is permits Fairfax County can take 3–6 weeks alone. Start the process 2–3 months before your desired completion date."}],["$","$L17",null,{"href":"/how-long-to-build-a-deck-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Full timeline breakdown →"}],false]}]
a:["$","section","best-time",{"id":"best-time","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"8. Best Time to Build"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"February–April for best pricing and availability. May–August is peak season with 4–6 week waits. September–November is the second-best window. Winter builds get 10–15% better pricing due to lower demand."}],["$","$L17",null,{"href":"/best-time-to-build-a-deck-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Month-by-month building calendar →"}],["$","div",null,{"style":{"background":"var(--color-primary)","color":"#fff","borderRadius":8,"padding":"2rem","marginTop":"2rem","textAlign":"center"},"children":[["$","h3",null,{"style":{"fontSize":"1.3rem","fontWeight":700,"marginBottom":"0.5rem"},"children":"Ready to Start Your Project?"}],["$","p",null,{"style":{"marginBottom":"1rem","opacity":0.9},"children":"Free on-site consultation · Detailed estimate in 48 hours · We handle permits & HOA"}],["$","div",null,{"style":{"display":"flex","gap":"1rem","justifyContent":"center","flexWrap":"wrap"},"children":[["$","a",null,{"href":"tel:+15716557207","style":{"background":"#fff","color":"var(--color-primary)","padding":"0.75rem 2rem","fontWeight":600,"borderRadius":6,"textDecoration":"none"},"children":"Call (571) 655-7207"}],["$","$L17",null,{"href":"/contact","style":{"border":"2px solid #fff","color":"#fff","padding":"0.75rem 2rem","fontWeight":600,"borderRadius":6,"textDecoration":"none"},"children":"Get Free Estimate"}]]}]]}]]}]
b:["$","section","railings",{"id":"railings","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"9. Railing Options"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Composite ($40–$70/ft): most popular, zero maintenance. Aluminum ($35–$60/ft): clean modern look. Cable rail ($60–$100/ft): best view, modern. Glass ($80–$150/ft): premium, unobstructed. Check HOA guidelines some restrict cable and glass railings."}],["$","$L17",null,{"href":"/deck-railing-options-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"All railing options compared →"}],false]}]
c:["$","section","lighting",{"id":"lighting","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"10. Deck Lighting"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Post cap lights + stair risers = essential ($500–$1,200). Add under-rail LED strips for the popular package ($1,500–$3,000). Premium with recessed + smart controls: $3,000–$5,000+. Include lighting in the initial build 30–50% cheaper than retrofitting."}],["$","$L17",null,{"href":"/deck-lighting-ideas-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Lighting options and costs →"}],false]}]
