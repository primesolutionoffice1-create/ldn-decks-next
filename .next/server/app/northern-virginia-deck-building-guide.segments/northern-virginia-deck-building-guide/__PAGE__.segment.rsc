e:["$","section","roi",{"id":"roi","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"12. Does a Deck Add Value?"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Composite deck ROI: 65–80% at resale. Screened porch: 70–85%. Wood deck: 50–65%. In NoVA's competitive market, homes with finished outdoor spaces sell 3–5 days faster. A $35,000 Trex deck can add $21,000–$28,000 to your home value."}],["$","$L17",null,{"href":"/does-a-deck-add-value-to-your-home","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Full ROI data →"}],false]}]
f:["$","section","maintenance",{"id":"maintenance","style":{"marginBottom":"3rem","paddingTop":"1rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1rem","color":"var(--color-dark)"},"children":"13. Maintenance"}],["$","p",null,{"style":{"lineHeight":1.8,"marginBottom":"1rem","fontSize":"1rem"},"children":"Composite: wash 1–2x/year with soap and water. That's it. Wood: stain/seal every 1–2 years ($600–$2,000), sand, replace rotted boards. Virginia's freeze-thaw (50–80 cycles/winter) and humidity (70–90% in summer) make maintenance critical for wood and trivial for composite."}],["$","$L17",null,{"href":"/deck-maintenance-checklist-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.95rem"},"children":"Seasonal maintenance checklist →"}],false]}]
