16:["$","p",null,{"style":"$7:props:children:props:children:1:props:style","children":["Instead of choosing between a ",["$","$Le",null,{"href":"/deck-vs-patio-which-is-right","style":{"color":"var(--color-primary)","fontWeight":600},"children":"deck or a patio"}],", homeowners are combining both. A raised composite deck transitions via stairs to a ground-level ",["$","$Le",null,{"href":"/stamped-concrete-patio-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600},"children":"stone or stamped concrete patio"}]," with a fire pit. The combination creates visual interest, zone separation, and uses each material where it performs best."]}]
17:["$","p",null,{"style":"$7:props:children:props:children:1:props:style","children":"Composite decking provides warmth, comfort underfoot, and elevation for views. Stone provides durability around fire features, handles heavy furniture without compression marks, and creates a natural ground-level gathering space."}]
