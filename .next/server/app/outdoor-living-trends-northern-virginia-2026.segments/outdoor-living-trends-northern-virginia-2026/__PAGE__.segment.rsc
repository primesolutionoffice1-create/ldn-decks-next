3a:["$","div",null,{"style":{"display":"grid","gap":"1rem","marginBottom":"2rem"},"children":[["$","div","1",{"style":{"background":"#f9f9f9","borderRadius":8,"padding":"1.5rem","borderLeft":"4px solid var(--color-primary)"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.5rem"},"children":["#","1",": ","Deck + Screened Porch Combo (70-85% ROI)"]}],["$","p",null,{"style":{"lineHeight":1.7,"margin":0},"children":"This combination checks every box for Northern Virginia buyers: outdoor entertaining, bug-free relaxation, and weather protection. It's the single most valuable outdoor living investment in the NoVA market."}]]}],["$","div","2",{"style":{"background":"#f9f9f9","borderRadius":8,"padding":"1.5rem","borderLeft":"4px solid var(--color-primary)"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.5rem"},"children":["#","2",": ","Under-Deck Drainage ($3K-$6K, Exceptional Value)"]}],["$","p",null,{"style":{"lineHeight":1.7,"margin":0},"children":"Dollar-for-dollar, this is the best upgrade for elevated decks. A $5,000 investment creates hundreds of square feet of dry, usable space underneath your deck. Buyers immediately understand the value."}]]}],["$","div","3",{"style":{"background":"#f9f9f9","borderRadius":8,"padding":"1.5rem","borderLeft":"4px solid var(--color-primary)"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.5rem"},"children":["#","3",": ","Composite Decking Over Wood (65-80% ROI)"]}],["$","p",null,{"style":{"lineHeight":1.7,"margin":0},"children":"Composite decks command 15-20% higher resale value than wood decks of the same size. The maintenance-free aspect is a major selling point — buyers in this market don't want weekend staining projects."}]]}],["$","div","4",{"style":{"background":"#f9f9f9","borderRadius":8,"padding":"1.5rem","borderLeft":"4px solid var(--color-primary)"},"children":[["$","h3",null,{"style":{"fontSi