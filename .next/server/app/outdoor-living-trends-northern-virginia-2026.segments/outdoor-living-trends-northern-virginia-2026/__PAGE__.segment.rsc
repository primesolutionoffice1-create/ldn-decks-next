2e:["$","p",null,{"style":"$7:props:children:props:children:1:props:style","children":["With over 60% of Northern Virginia households owning pets, ",["$","$Le",null,{"href":"/pet-friendly-deck-design","style":{"color":"var(--color-primary)","fontWeight":600},"children":"pet-friendly deck design"}]," has become a genuine design consideration. The most requested features: built-in pet gates at stair access points, railing with reduced baluster spacing (2-inch instead of 4-inch for small dogs), composite decking that resists claw scratches, and integrated pet washing stations."]}]
2f:["$","p",null,{"style":"$7:props:children:props:children:1:props:style","children":"Composite decking is inherently pet-friendly — no splinters, no toxic stain chemicals, and the capped polymer surface resists scratching better than wood. Dark colors show less pet hair than light tones."}]
