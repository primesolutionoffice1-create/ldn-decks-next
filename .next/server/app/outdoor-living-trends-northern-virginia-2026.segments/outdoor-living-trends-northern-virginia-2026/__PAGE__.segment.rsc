21:["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem","marginTop":"2.5rem"},"children":"8. Low-Profile Ground-Level Decks"}]
22:["$","p",null,{"style":"$7:props:children:props:children:1:props:style","children":"Not every deck needs to be elevated. Ground-level floating decks (6–18 inches above grade) are surging in popularity for flat yards, as transitions from sliding doors, or as standalone patio alternatives. They don't require railings (under 30 inches above grade), which reduces cost and creates a sleek, open feel."}]
