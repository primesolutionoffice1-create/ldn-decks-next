23:["$","ol",null,{"style":{"paddingLeft":"1.5rem","marginBottom":"2rem"},"children":[["$","li","0",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Composite decking (capped)"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"No splinters in paws, resists claw scratches, cleans pet messes easily with soap and water. The #1 pet-friendly upgrade."}]]}],["$","li","1",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Close-spaced balusters (3\" or less)"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"Standard code is 4\" max, but for small dogs and puppies, specify 3\" spacing. Prevents head entrapment. Avoid cable railings dogs can squeeze through or get caught."}]]}],["$","li","2",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Pet gates at stairs"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"Built-in gate mounts at the top and bottom of deck stairs. Keeps dogs on the deck when unsupervised. We can integrate gate hardware into the railing design."}]]}],["$","li","3",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Shade zone"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"A pergola or canopy section so your dog has escape from direct sun. Virginia summers hit 90°F+ deck surfaces can reach 130°F. Dogs need shade."}]]}],["$","li","4",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Fresh water station"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"A built-in hose bib connection or designated area for a water bowl. Small detail that makes daily life easier."}]]}],["$","li","5",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Easy-access ramp (for older dogs)"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"If your deck is elevated, a wide ramp alongside the stairs lets senior dogs or dogs with joint issues access the deck comfortably."}]]}],["$","li","6",{"style":{"marginBottom":"1.25rem","lineHeight":1.7},"children":[["$","strong",null,{"children":"Designated wash zone"}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"A section of the deck near the hose connection with a slight drainage slope perfect for post-walk paw rinses and summer baths. Composite surfaces handle water without damage."}]]}]]}]
