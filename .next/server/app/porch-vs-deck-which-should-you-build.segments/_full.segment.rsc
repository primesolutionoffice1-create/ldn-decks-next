c:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is a porch or deck a better investment?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Screened porches return 70-85% at resale vs 65-80% for composite decks. Porches also extend usable outdoor season to 9-10 months vs 5-6 for open decks. However, porches cost 40-60% more upfront.\"}},{\"@type\":\"Question\",\"name\":\"How much more does a porch cost than a deck?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A screened porch costs $25,000-$70,000 vs $15,000-$45,000 for a comparable composite deck in Northern Virginia. The porch premium covers roof framing, screening, ceiling, and often electrical work.\"}},{\"@type\":\"Question\",\"name\":\"Can you convert a deck into a screened porch?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, if the existing deck framing can support the added roof and wall weight. We inspect the structure first. Converting an existing deck typically costs $20,000-$40,000 depending on size and features.\"}}]}"}}],["$","section",null,{"style":{"background":"var(--color-dark)","color":"#fff","padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","h1",null,{"style":{"fontSize":"2.5rem","fontWeight":700,"marginBottom":"1rem"},"children":"Porch vs Deck: Which Should You Build?"}],["$","p",null,{"style":{"color":"#ccc","fontSize":"1.1rem"},"children":"Cost, ROI, usable season, and maintenance compared for Northern Virginia homeowners"}]]}]}],["$","section",null,{"style":{"background":"#fff3e0","borderLeft":"4px solid var(--color-primary)","padding":"1.5rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","p",null,{"style":{"fontWeight":600,"marginBottom":"0.5rem"},"c