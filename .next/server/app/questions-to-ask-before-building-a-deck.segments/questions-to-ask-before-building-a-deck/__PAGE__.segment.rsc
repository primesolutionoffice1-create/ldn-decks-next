,["$","p",null,{"style":{"lineHeight":1.7,"color":"#555"},"children":"Couples: 150-200 sqft. Families: 300-400 sqft. Entertainers: 500+. Don't exceed 20-25% of your backyard."}],"$L5"]}],"$L6"]]}],"$L7","$L8","$L9","$La"],"$Lb","$Lc"]}]}],"$Ld","$Le"],["$Lf"],"$L10"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Jebrcr4Vyd2YosxlccnHN"}
