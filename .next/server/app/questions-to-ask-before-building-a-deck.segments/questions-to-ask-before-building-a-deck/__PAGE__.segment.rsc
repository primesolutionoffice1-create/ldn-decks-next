,". ","How long do permits take?"]}],["$","p",null,{"style":{"lineHeight":1.7,"color":"#555"},"children":"Loudoun: 10-15 business days. Fairfax: 3-6 weeks. Prince William: 2-4 weeks. Start early."}],["$","$L4",null,{"href":"/how-long-to-build-a-deck-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.9rem"},"children":"Read more →"}]]}]]]}]
9:["$","div","Contractor Selection",{"style":{"marginBottom":"3rem"},"children":[["$","h2",null,{"style":{"fontSize":"1.6rem","fontWeight":700,"marginBottom":"1.5rem","borderBottom":"2px solid var(--color-primary)","paddingBottom":"0.5rem"},"children":"Contractor Selection"}],[["$","div","0",{"style":{"marginBottom":"1.5rem"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.5rem"},"children":[13,". ","How do I choose a deck builder?"]}],["$","p",null,{"style":{"lineHeight":1.7,"color":"#555"},"children":"Verify VA license at dpor.virginia.gov. Check insurance. Ask for 3-5 recent local references. Get itemized written estimate. Confirm warranty in writing."}],["$","$L4",null,{"href":"/how-to-choose-a-deck-builder-northern-virginia","style":{"color":"var(--color-primary)","fontWeight":600,"fontSize":"0.9rem"},"children":"Read more →"}]]}],["$","div","1",{"style":{"marginBottom":"1.5rem"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.5rem"},"children":[14,". ","How many quotes should I get?"]}],["$","p",null,{"style":{"lineHeight":1.7,"color":"#555"},"children":"2-3 from licensed contractors. Compare scope and materials, not just price. Cheapest quote usually means cheapest materials or no permits."}],"$undefined"]}],["$","div","2",{"style":{"marginBottom":"1.5rem"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.5rem"},"children":[15,". ","What red flags should I watch for?"]}],["$","p",null,{"style":{"lineHeight":1.7,"color":"#555"},"children":"No VA license, cash-only demands, no written warranty, suggests skipping permits, can't show recent local work, pressure to sign immediately."}],"$undefined"]}],["$","div","3",{"style":{"marginBottom":"1.5rem"},"children":[["$","h3",null,{"style":{"fontSize":"1.1rem","fontWeight":600,"marginBottom":"0.5rem"},"children":[16,". ","What should the estimate include?"]}],["$","p",null,{"style":{"lineHeight":1.7,"color":"#555"},"children":"Itemized materials (brand, model, color), labor, permits, dumpster, cleanup, timeline, warranty terms all in writing. Lump-sum quotes hide problems."}],"$undefined"]}]]]}]
