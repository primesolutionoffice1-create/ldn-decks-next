22:["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":"The construction industry in Northern Virginia faces a growing skilled labor shortage. As experienced deck builders, we see this challenge every day — talented tradespeople are retiring faster than new ones are entering the field. This scholarship is our small contribution to reversing that trend."}]
23:["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":["We encourage students at ",["$","strong",null,{"children":"NOVA Community College"}],", ",["$","strong",null,{"children":"George Mason University"}],", ",["$","strong",null,{"children":"Virginia Tech"}],", ",["$","strong",null,{"children":"Germanna Community College"}],", and other Virginia institutions to apply. Whether you're studying construction management, learning carpentry at a trade school, or pursuing an apprenticeship, we want to hear from you."]}]
24:["$","p",null,{"style":{"marginBottom":"2rem","lineHeight":1.7},"children":["Questions? Email us at ",["$","a",null,{"href":"mailto:office@ldndecks.com","style":{"color":"var(--color-primary)","fontWeight":600},"children":"office@ldndecks.com"}]," or call ",["$","a",null,{"href":"tel:+15716557207","style":{"color":"var(--color-primary)","fontWeight":600},"children":"(571) 655-7207"}],"."]}]
25:["$","h2",null,{"style":{"fontSize":"1.8rem","fontWeight":700,"marginBottom":"1.5rem"},"children":"About LDN Decks"}]
26:["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":["LDN Decks is Northern Virginia's top-rated custom deck builder, serving Loudoun, Fairfax, Prince William, Arlington, and Stafford counties since 2001. We are a ",["$","strong",null,{"children":"Trex Platinum Partner"}]," (top 1% nationally) and ",["$","strong",null,{"children":"TimberTech Certified Installer"}],", specializing in premium composite decks, screened porches, pergolas, and outdoor living spaces. ",["$","$L17",null,{"href":"/","style":{"color":"var(--color-primary)","fontWeight":600},"children":"Learn more about us →"}]]}]
