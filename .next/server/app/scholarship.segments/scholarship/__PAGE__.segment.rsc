e:["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":["LDN Decks is Northern Virginia's top-rated custom deck builder, serving Loudoun, Fairfax, Prince William, Arlington, and Stafford counties since 2001. We are a ",["$","strong",null,{"children":"Trex Platinum Partner"}]," (top 1% nationally) and ",["$","strong",null,{"children":"TimberTech Certified Installer"}],", specializing in premium composite decks, screened porches, pergolas, and outdoor living spaces. ",["$","$L12",null,{"href":"/","style":{"color":"var(--color-primary)","fontWeight":600},"children":"Learn more about us →"}]]}]
