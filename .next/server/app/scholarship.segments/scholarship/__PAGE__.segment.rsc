a:["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":"The construction industry in Northern Virginia faces a growing skilled labor shortage. As experienced deck builders, we see this challenge every day — talented tradespeople are retiring faster than new ones are entering the field. This scholarship is our small contribution to reversing that trend."}]
b:["$","p",null,{"style":{"marginBottom":"1rem","lineHeight":1.7},"children":["We encourage students at ",["$","strong",null,{"children":"NOVA Community College"}],", ",["$","strong",null,{"children":"George Mason University"}],", ",["$","strong",null,{"children":"Virginia Tech"}],", ",["$","strong",null,{"children":"Germanna Community College"}],", and other Virginia institutions to apply. Whether you're studying construction management, learning carpentry at a trade school, or pursuing an apprenticeship, we want to hear from you."]}]
