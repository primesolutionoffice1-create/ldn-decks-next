d:["$","$1","c",{"children":[["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Deck Safety Inspection\",\"description\":\"Professional structural deck inspection in Northern Virginia. Ledger board, posts, joists, railings checked.\",\"provider\":{\"@type\":\"LocalBusiness\",\"@id\":\"https://www.ldndecks.com/#organization\",\"name\":\"Loudoun Decks\"},\"areaServed\":[{\"@type\":\"AdministrativeArea\",\"name\":\"Loudoun County, VA\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Fairfax County, VA\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Prince William County, VA\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Arlington County, VA\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Stafford County, VA\"}],\"offers\":{\"@type\":\"Offer\",\"priceSpecification\":{\"@type\":\"UnitPriceSpecification\",\"priceCurrency\":\"USD\",\"price\":\"150\",\"unitText\":\"per project\"}},\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"5.0\",\"reviewCount\":\"41\",\"bestRating\":\"5\"}}"}}],["$","$L1b",null,{"subtext":"Deck Inspection Services","title":"Comprehensive Deck Inspection for $350","description":"Ensure the safety, structural integrity, and longevity of your deck with our professional inspection services. We identify hidden rot, structural issues, and potential safety hazards."}],["$","section",null,{"style":{"padding":"80px 20px","maxWidth":"1200px","margin":"0 auto","textAlign":"center"},"children":[["$","h2",null,{"style":{"fontSize":"36px","marginBottom":"20px","fontWeight":"700"},"children":"Providing Expert Deck Restoration Services"}],["$","p",null,{"style":{"fontSize":"18px","color":"#555","maxWidth":"800px","margin":"0 auto 50px","lineHeight":"1.6"},"children":["Over time, even the most well-built decks fall victim to weathering, moisture, and foundational settling. Our $350 specialized deck inspection evaluates your entire structure from the footers to the railings. If we find issues, our restoration experts can repair, reinforce, and completely revitalize your older deck through ",["$","$L18",null,{"href":"/services/deck-resurfacing","children":"deck resurfacing"}],", saving you thousands compared to a full ",["$","$L18",null,{"href":"/services/new-decks","children":"new deck build"}],"."]}],["$","div",null,{"style":{"display":"grid","gridTemplateColumns":"repeat(auto-fit, minmax(250px, 1fr))","gap":"20px","alignItems":"stretch"},"children":[["$","div",null,{"style":{"position":"relative","height":"300px","borderRadius":"12px","overflow":"hidden","boxShadow":"0 10px 20px rgba(0,0,0,0.1)"},"children":["$","$L1c",null,{"src":"/torndeck.webp","alt":"Old deck damage","fill":true,"sizes":"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 25vw","style":{"objectFit":"cover"}}]}],["$","div",null,{"style":{"position":"relative","height":"300px","borderRadius":"12px","overflow":"hidden","boxShadow":"0 10px 20px rgba(0,0,0,0.1)"},"children":["$","$L1c",null,{"src":"/torndeck1.webp","alt":"Weathered deck boards","fill":true,"sizes":"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 25vw","style":{"objectFit":"cover"}}]}],["$","div",null,{"style":{"position":"relative","height":"300px","borderRadius":"12px","overflow":"hidden","boxShadow":"0 10px 20px rgba(0,0,0,0.1)"},"children":["$","$L1c",null,{"src":"/torndeck2.webp","alt":"Deck requiring restoration","fill":true,"sizes":"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 25vw","style":{"objectFit":"cover"}}]}],["$","div",null,{"style":{"position":"relative","height":"300px","borderRadius":"12px","overflow":"hidden","boxShadow":"0 10px 20px rgba(0,0,0,0.1)"},"children":["$","$L1c",null,{"src":"/torndeck3.jpg","alt":"Deck structural inspection","fill":true,"sizes":"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 25vw","style":{"objectFit":"cover"}}]}]]}]]}],["$","section",null,{"style":{"padding":"20px 20px 80px","maxWi