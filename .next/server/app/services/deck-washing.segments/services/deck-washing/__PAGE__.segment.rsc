2:T5e8,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How often should I have my deck washed in Virginia?","acceptedAnswer":{"@type":"Answer","text":"We recommend a professional cleaning at least once every 12 to 18 months, typically scheduled in the late spring after the heavy oak and pine pollen drop has settled."}},{"@type":"Question","name":"Will the cleaning chemicals harm my landscaping or pets?","acceptedAnswer":{"@type":"Answer","text":"We employ extensive property protection measures. We pre-wet and post-wet all surrounding grass and shrubs. The detergents we use are heavily diluted and break down quickly into harmless salts when flushed with water. It is completely safe for pets once the deck has dried."}},{"@type":"Question","name":"Do composite decks really need to be washed?","acceptedAnswer":{"@type":"Answer","text":"Yes. While composite decks (like Trex) are highly resistant to moisture, the dirt and pollen that settle on top of them can still grow mold. A bi-annual soft wash keeps them looking brand new and fulfills the maintenance requirements of the manufacturer warranty."}},{"@type":"Question","name":"Do you also apply stain and sealant after washing?","acceptedAnswer":{"@type":"Answer","text":"Yes, once the organic wood has been thoroughly cleaned, neutralized, and allowed to dry to a proper moisture content level (usually 24-48 hours later depending on sun exposure), we can return to apply premium contractor-grade sealants."}}]}0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Professional Deck Washing\",\"provider\":{\"@type\":\"LocalBusiness\",\"name\":\"Loudoun Decks\"},\"areaServed\":[{\"@type\":\"State\",\"name\":\"Virginia\"}],\"description\":\"Professional exterior residential deck cleaning, soft washing, and wood brightening services in Northern Virginia.\"}"}}],["$","$L3",null,{"subtext":"Maintenance & Restoration","title":"Professional Deck Washing Services","description":"Safely strip away years of grime, dangerous mildew, and gray oxidation without damaging your wood or composite boards."}],["$","section",null,{"className":"ServiceMain-module___ICLAW__section","children":["$","div",null,{"className":"ServiceMain-module___ICLAW__container","children":[["$","div",null,{"className":"ServiceMain-module___ICLAW__imagesCol","children":[["$","div",null,{"className":"ServiceMain-module___ICLAW__frameOutline"}],["$","div",null,{"className":"ServiceMain-module___ICLAW__subImgWrapper","children":["$","$L4",null,{"src":"/homeimg4.webp","alt":"Service Detail","fill":true,"className":"ServiceMain-module___ICLAW__imgProps","sizes":"(max-width: 768px) 100vw, 400px"}]}],["$","div",null,{"className":"ServiceMain-module___ICLAW__mainImgWrapper","children":["$","$L4",null,{"src":"/outdoorwashing2.webp","alt":"Service Build","fill":true,"className":"ServiceMain-module___ICLAW__imgProps","sizes":"(max-width: 768px) 100vw, 600px"}]}]]}],["$","div",null,{"className":"ServiceMain-module___ICLAW__contentCol","children":[["$","div",null,{"className":"ServiceMain-module___ICLAW__labelWrapper","children":[["$","span",null,{"className":"ServiceMain-module___ICLAW__label","children":"Protect Your Investment"}],["$","span",null,{"className":"ServiceMain-module___ICLAW__line"}]]}],["$","h2",null,{"className":"ServiceMain-module___ICLAW__title","children":"Safe, Effective Restoration"}],["$","p",null,{"className":"ServiceMain-module___ICLAW__description","children":"Whether you have an expensive IPE hardwood deck or low-maintenance Trex boards, aggressive high-pressure washing can cause irreversible damage. Loudoun Decks employs advanced 'Soft Washing' techniques that rely on high water volume and specialized detergents to melt dirt away effortlessly."}],"$L5","$L6"]}]]}]}],"$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le"]}],["$Lf","$L10"],"$L11"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Jebrcr4Vyd2YosxlccnHN"}
5:["$","h4",null,{"className":"ServiceMain-module___ICLAW__listTitle","children":"The Benefits of Professional Soft Washing:"}]
6:["$","ul",null,{"className":"ServiceMain-module___ICLAW__list","children":[["$","li","0",{"children":[["$","svg",null,{"width":"20","height":"20","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}],["$","span",null,{"children":"Zero risk of splintering or tearing natural wood grain"}]]}],["$","li","1",{"children":[["$","svg",null,{"width":"20","height":"20","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}],["$","span",null,{"children":"Eco-friendly detergents neutralize the root spores of algae"}]]}],["$","li","2",{"children":[["$","svg",null,{"width":"20","height":"20","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}],["$","span",null,{"children":"Deep cleans the porous surface properly before applying stains"}]]}],["$","li","3",{"children":[["$","svg",null,{"width":"20","height":"20","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}],["$","span",null,{"children":"Instantly raises the curb appeal of your backyard landscape"}]]}]]}]
7:["$","section",null,{"className":"ServiceContentExpansion-module__6_-y9q__section","children":["$","div",null,{"className":"ServiceContentExpansion-module__6_-y9q__container","children":[["$","div","0",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Why Your Deck Needs Professional Washing"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["In Northern Virginia, the combination of intense spring pollen, humid summers, and freeze-thaw winter cycles creates the perfect breeding ground for organic growth on outdoor surfaces. Allowed to fester, mold, mildew, and algae will root deep into the pores of your wood or composite decking."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Beyond looking unsightly, this organic buildup becomes incredibly slippery and dangerous when wet. More importantly, mold feeds on the organic fibers of wood decks, accelerating rot and structurally compromising your investment. Professional washing is not just a cosmetic upgrade; it is critical preventative maintenance."]}]]}],["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Algae & Mildew Eradication",":"]}]," ",["We use eco-friendly chemical soft-washes to kill the root spores of algae, rather than just blasting the top layer away."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Restored Traction",":"]}]," ",["Removing the slippery micro-film of mildew restores the original friction to your stairs and boards, ensuring family safety."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Pollen & Tannin Removal",":"]}]," ",["We lift out the deep-seated yellow oak pollen and naturally occurring tannin stains that discolor your deck's appearance."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Prep for Staining",":"]}]," ",["Wood pores must be completely free of dirt and old oils before applying a new semi-transparent or solid stain. Proper washing is step one."]]}]]}]]}],["$","div","1",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Danger of DIY High-Pressure Washing"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["The most common mistake homeowners make is renting a 3000 PSI pressure washer and blasting their pressure-treated wood or Trex boards at point-blank range."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["High pressure water acts like a liquid buzzsaw. On natural wood, it will 'fur' the boards by shredding the cellulose fibers, leading to massive splintering. On composite decks, excessive pressure will strip the protective acrylic capping, voiding the manufacturer's warranty entirely. We utilize specialized 'Soft Washing' techniques that rely on premium detergents and high water volume, not high pressure, to safely lift dirt."]}]]}],["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":["$L12"," ",["Our low-pressure nozzles ensure the wood grain stays tight and smooth, readying it for sealants."]]}],"$L13","$L14","$L15"]}]]}]]}]}]
8:["$","$L16",null,{"title":"Our Soft Washing Methodology","steps":[{"title":"Property Protection","desc":"We begin by watering down adjacent plants and covering delicate outdoor furniture or exposed electrical outlets."},{"title":"Chemical Application","desc":"A bespoke mixture of surfactants and mildew-cides is applied at low pressure, allowing it to dwell and break down organic bonds."},{"title":"Volume Rinsing","desc":"Using high-GPM (Gallons Per Minute) machines, we flush the dirt away using very low pressure (under 800 PSI)."},{"title":"Wood Brightening","desc":"For natural wood decks, an optional oxalic acid brightener is applied to restore the wood's natural pH and blonde color."}]}]
