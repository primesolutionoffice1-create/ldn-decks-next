sion Plumbing & Squaring"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Laser-leveling to ensure your new door swings effortlessly, preventing future binding or draft gaps."}]]}]]}],["$","div","2",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"className":"$undefined","children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Heavy Insulation"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Applying low-expansion spray foam between the door jamb and the rough framing to maximize your HVAC efficiency."}]]}]]}],["$","div","3",{"className":"ServiceInclusions-module__sDDdhG__card","children":[["$","div",null,{"className":"ServiceInclusions-module__sDDdhG__iconWrapper","children":["$","svg",null,{"width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"3","strokeLinecap":"round","strokeLinejoin":"round","children":["$","polyline",null,{"points":"20 6 9 17 4 12"}]}]}],["$","div",null,{"className":"$undefined","children":[["$","h3",null,{"className":"ServiceInclusions-module__sDDdhG__itemTitle","children":"Finished Carpentry"}],["$","p",null,{"className":"ServiceInclusions-module__sDDdhG__itemDesc","children":"Applying premium caulking, weatherstripping, and seamlessly integrating new interior and exterior trim."}]]}]]}]]}]]}]}]
23:["$","$L34",null,{"title":"Entry Door FAQs","faqs":[{"q":"How long does a professional door installation take?","a":"Assuming no severe structural rot is found in the frame, a standard full-frame entry door replacement typically takes our crew one full day to complete, including interior trim finishing and cleanup."},{"q":"Are fiberglass doors better than wood?","a":"In terms of longevity and maintenance, yes. Fiberglass is highly resistant to Maryland and Virginia's humid summers and freezing winters. It will not warp, swell, or rot like wood, yet it provides the exact same visual aesthetic when properly stained or painted."},{"q":"Can you expand my doorway to add sidelites?","a":"Yes. Expanding a standard single door into a grand entryway with a double door or sidelites involves significant structural reframing (installing a wider header). Our heavy-carpentry teams are fully equipped to handle this structural modification safely."},{"q":"Do you install smart locks and hardware?","a":"Yes. You can supply your own smart lock or keypad deadbolt, and our technicians will professionally bore the door and install the electronic hardware during the door's final installation."}]}]
