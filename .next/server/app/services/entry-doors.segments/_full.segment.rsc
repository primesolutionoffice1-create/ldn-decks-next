20:["$","section",null,{"className":"ServiceContentExpansion-module__6_-y9q__section","children":["$","div",null,{"className":"ServiceContentExpansion-module__6_-y9q__container","children":[["$","div","0",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Why Your Front Entry Door Matters"}],["$","div",null,{"className":"$undefined","children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Your front door is the focal point of your property's exterior. It is the first thing guests interact with, the primary barrier for your home's security, and a critical component in your home's energy efficiency. In Northern Virginia's climate, a poorly insulated or warped entry door can cost you hundreds of dollars in lost HVAC efficiency every year."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Loudoun Decks provides premium entry door installation services. We don't just hang a door on old hinges; we execute a full-frame replacement. This ensures your new door is perfectly plumb, heavily insulated, and visually stunning, instantly elevating your curb appeal."]}]]}],["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Energy Efficiency",":"]}]," ",["Modern doors feature polyurethane foam cores that provide up to five times the insulating value of old wood doors."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Enhanced Security",":"]}]," ",["Reinforced lock blocks, heavy-duty strike plates, and multi-point locking systems keep your family safe."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Instant Curb Appeal",":"]}]," ",["A vibrant, structurally impressive front door yields one of the highest ROI percentages of any home remodel."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Weather Resistance",":"]}]," ",["Advanced sealing and sweeping technologies stop frustrating drafts and water intrusion."]]}]]}]]}],["$","div","1",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Choosing the Right Door Material"}],["$","div",null,{"className":"$undefined","children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Gone are the days when a heavy slab of solid wood was your only option. Modern engineering has introduced incredible materials tailored to different needs and budgets."]}]]}],["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Fiberglass Doors",":"]}]," ",["The most popular choice today. Fiberglass won't warp, rot, or rust. It can be manufactured to perfectly mimic the grain of real mahogany or oak, but requires a fraction of the maintenance."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Steel Doors",":"]}]," ",["The ultimate choice for structural security and affordability. Steel doors offer exceptional insulating value and provide a sleek, modern, flush appearance."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":["$L31"," ",["For historic homes or purists who demand the weight and authenticity of real wood. While they require routine maintenance and sealing, nothing beats the character of natural wood."]]}],"$L32"]}]]}],"$L33"]}]}]
