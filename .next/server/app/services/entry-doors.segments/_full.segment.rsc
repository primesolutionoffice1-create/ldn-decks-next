33:["$","div","2",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Importance of Full-Frame Replacement"}],["$","div",null,{"className":"$undefined","children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Many big-box store contractors offer 'slab replacement'—simply ripping the old door off the hinges and screwing a new one in the existing frame. This is a massive mistake if you want true performance."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["At Loudoun Decks, we emphasize full-frame replacement. We remove the entire door unit down to the rough opening studs. This allows us to assess and repair any hidden water rot in the sill, install brand new threshold flashing, and shoot low-expansion foam insulation entirely around the new frame to guarantee a perfect seal."]}]]}],["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Rot Repair",":"]}]," ",["We fix the underlying structural damage that previous leaky doors left behind."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Flashing & Sealing",":"]}]," ",["We employ architectural-grade flashing tape and caulk to ensure water never penetrates the subfloor."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Hardware Installation",":"]}]," ",["Precision drilling for deadbolts, smart-locks, and premium handlesets."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Trim & Molding",":"]}]," ",["Finished with beautiful interior casing and exterior brickmould that matches your home's aesthetics."]]}]]}]]}]
