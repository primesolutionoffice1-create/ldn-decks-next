1b:T5a9,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How long does a professional door installation take?","acceptedAnswer":{"@type":"Answer","text":"Assuming no severe structural rot is found in the frame, a standard full-frame entry door replacement typically takes our crew one full day to complete, including interior trim finishing and cleanup."}},{"@type":"Question","name":"Are fiberglass doors better than wood?","acceptedAnswer":{"@type":"Answer","text":"In terms of longevity and maintenance, yes. Fiberglass is highly resistant to Maryland and Virginia's humid summers and freezing winters. It will not warp, swell, or rot like wood, yet it provides the exact same visual aesthetic when properly stained or painted."}},{"@type":"Question","name":"Can you expand my doorway to add sidelites?","acceptedAnswer":{"@type":"Answer","text":"Yes. Expanding a standard single door into a grand entryway with a double door or sidelites involves significant structural reframing (installing a wider header). Our heavy-carpentry teams are fully equipped to handle this structural modification safely."}},{"@type":"Question","name":"Do you install smart locks and hardware?","acceptedAnswer":{"@type":"Answer","text":"Yes. You can supply your own smart lock or keypad deadbolt, and our technicians will professionally bore the door and install the electronic hardware during the door's final installation."}}]}d:["$","$1","c",{"children":[["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1b"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Custom Entry Door Installation\",\"provider\":{\"@type\":\"LocalBusiness\",\"name\":\"Loudoun Decks\"},\"areaServed\":[{\"@type\":\"State\",\"name\":\"Virginia\"}],\"description\":\"Professional exterior entry door replacement and full-frame installation services in Northern Virginia.\"}"}}],["$","$L1c",null,{"subtext":"Entry & Exterior Doors","title":"Custom Entry Door Installation","description":"Dramatically improve the curb appeal, security, and total energy efficiency of your property with professional entry door installation in Northern Virginia."}],["$","section",null,{"className":"ServiceMain-module___ICLAW__section","children":["$","div",null,{"className":"ServiceMain-module___ICLAW__container","children":[["$","div",null,{"className":"ServiceMain-module___ICLAW__imagesCol","children":[["$","div",null,{"className":"ServiceMain-module___ICLAW__frameOutline"}],["$","div",null,{"className":"ServiceMain-module___ICLAW__subImgWrapper","children":["$","$L1d",null,{"src":"/images/img26.jpeg","alt":"Service Detail","fill":true,"className":"ServiceMain-module___ICLAW__imgProps","sizes":"(max-width: 768px) 100vw, 400px"}]}],["$","div",null,{"className":"ServiceMain-module___ICLAW__mainImgWrapper","children":["$","$L1d",null,{"src":"/images/img24.jpeg","alt":"Service Build","fill":true,"className":"ServiceMain-module___ICLAW__imgProps","sizes":"(max-width: 768px) 100vw, 600px"}]}]]}],["$","div",null,{"className":"ServiceMain-module___ICLAW__contentCol","children":[["$","div",null,{"className":"ServiceMain-module___ICLAW__labelWrapper","children":[["$","span",null,{"className":"ServiceMain-module___ICLAW__label","children":"Make a Lasting First Impression"}],["$","span",null,{"className":"ServiceMain-module___ICLAW__line"}]]}],["$","h2",null,{"className":"ServiceMain-module___ICLAW__title","children":"The Gateway to Your Home"}],["$","p",null,{"className":"ServiceMain-module___ICLAW__description","children":"Your entry door is the most hard-working mechanical component of your home's exterior. It opens and closes thousands of times a year while constantly enduring harsh sun, driving rain, and freezing temperatures. Upgrading your entry door is an investment in both your home's security footprint and its architectural stature."}],"$L1e","$L1f"]}]]}]}],"$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27"]}],["$L28","$L29"],"$L2a"]}]
