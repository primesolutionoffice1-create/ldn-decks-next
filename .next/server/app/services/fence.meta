{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/fence/layout,_N_T_/services/fence/page,_N_T_/services/fence"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/fence/__PAGE__",
    "/services/fence",
    "/services",
    "/_index",
    "/_head"
  ]
}