8:["$","section",null,{"className":"ServiceContentExpansion-module__6_-y9q__section","children":["$","div",null,{"className":"ServiceContentExpansion-module__6_-y9q__container","children":[["$","div","0",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Understanding the Difference: Pergolas vs Gazebos"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["When planning to add vertical architecture to your backyard, the terms 'pergola' and 'gazebo' are often used interchangeably, but they serve very different functional purposes."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["A pergola is an outdoor structure featuring an open-beam roof supported by vertical columns or pillars. Its primary purpose isn't to block out the rain, but rather to diffuse harsh sunlight, provide a framework for climbing vines, and create a gorgeous architectural transition space. Conversely, a gazebo acts as an outdoor room. It features a fully closed, pitched roof (often shingled to match your house) and provides total shelter from the elements, allowing you to enjoy your backyard even during summer downpours."]}]]}],["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Pergola Function",":"]}]," ",["Best for partial shade, visual definition, and an airy, open environment."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Gazebo Function",":"]}]," ",["Best for complete weather protection and creating a distinctly enclosed outdoor room."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Material Choices",":"]}]," ",["Available in premium natural woods (Cedar, Redwood) or low-maintenance composites and aluminum."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Placement Integration",":"]}]," ",["Can be built freestanding in a garden or structurally tied into an existing deck or patio."]]}]]}]]}],["$","div","1",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Custom Pergola Designs for Northern Virginia"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["A pergola is the perfect addition to a bluestone patio or Trex deck. It creates a defined 'ceiling' that instantly makes the outdoor area feel cozy and intentional."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["At Loudoun Decks, we don't install flimsy, kit-in-a-box pergolas. Our structures are custom-engineered. We frequently incorporate automated louvered roof systems (allowing you to open and close the roof slits mechanically), integrated lighting, and outdoor ceiling fans to push away the heavy Virginia humidity."]}]]}],["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Attached vs. Freestanding",":"]}]," ",["We can anchor them directly to your home's ledger board or construct them as standalone backyard focal points."]]}],"$L13","$L14","$L15"]}]]}],"$L16"]}]}]
