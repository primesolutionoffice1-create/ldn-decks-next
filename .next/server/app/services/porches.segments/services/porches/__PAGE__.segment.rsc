15:["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["As your custom deck builder and porch specialist, we can design hybrid spaces that feature both screened and open sections, allowing you the best of both worlds depending on the time of day and the season."]}]
16:["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Protection",":"]}]," ",["Screened porches keep out bugs, debris, and light rain, allowing for upholstery and electronics."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Architecture",":"]}]," ",["Covered porches allow for dramatic rooflines and exposed timber beam aesthetics."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Value",":"]}]," ",["Integrated porch structures frequently command higher premiums during home appraisals in NoVA."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Comfort",":"]}]," ",["Adding a roof alone can drop the temperature of your outdoor space by 10-15 degrees in mid-summer."]]}]]}]
17:["$","div","2",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Interior Finishes: Creating the 'Outdoor Living Room'"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["The true magic of a custom porch build in Northern Virginia lies in the interior finishes. We go far beyond standard pressure-treated lumber. Our clients in Lansdowne and Leesburg often opt for tongue-and-groove cedar ceilings, mahogany flooring, or low-maintenance PVC beadboard. These materials elevate the space from a 'porch' to a 'luxury retreat.' We pay close attention to the details-recessed LED lighting on dimmers, high-powered ceiling fans for humid afternoons, and even infrared heaters for crisp November nights."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Security and longevity are built into every finish. We use high-grade sealants and hidden fastener systems to ensure that your porch looks as clean and professional as your home's interior. We also specialize in 'Eze-Breeze' vertical track windows, which allow you to convert your screened porch into a three-season room by sliding clear vinyl panels over the screens to block the wind and cold."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["By choosing a 5-Star Google Rated contractor, you ensure that these technical details-like electrical grounding and structural load-bearing roof connections-are handled by experts who value your family's safety above all else."]}]]}],"$undefined"]}]
18:["$","div","3",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Permit & Planning Journey in NoVA"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Adding a roof structure to a deck or building a new porch from scratch changes the structural requirements of your home's foundation. This is why permitting is so critical in regions like Mount Vernon and Dale City. Every new post must be supported by footings that are calculated to handle the increased weight of the roof, as well as the 'snow load' requirements of Virginia winters. Our design team uses CAD software to ensure every beam and header is precisely sized for your specific dimensions."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We manage the entire permit cycle with your local building department, whether you are in Stafford County or the heart of Arlington. This including structural drawings, site plans, and coordinating with inspections. Our 'Full projects only' approach means we take responsibility for the entire lifecycle, so you don't have to worry about the red tape."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Our local presence means we have established relationships with building inspectors across NoVA, leading to faster approvals and fewer headaches for our clients. We position Loudoun Decks as a premium builder because we don't cut corners on these essential hidden details."]}]]}],"$undefined"]}]
