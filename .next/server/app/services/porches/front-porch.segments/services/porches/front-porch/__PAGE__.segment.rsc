13:["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Portico",":"]}]," ",["Roof over front door only. Minimum footprint. Maximum curb appeal per dollar."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Full Front Porch",":"]}]," ",["Extends across full or partial facade. Full railing and roofline."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Wraparound Porch",":"]}]," ",["Continues around one or both sides. Traditional and highly desirable."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Second-Story Porch",":"]}]," ",["Above-garage or dormer porch. Premium complexity and character."]]}]]}]
14:["$","div","2",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"What to Expect: Process, Permitting & Pricing"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Front porch projects in Loudoun County, Fairfax County, and Prince William County require a building permit. This involves structural drawings, a site plan, and coordination with your county's building department. We manage this entirely in-house, including all engineering documentation. Permit processing typically takes 3-6 weeks in Northern Virginia, after which construction begins."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Construction timelines vary by project scope. A simple portico can be completed in 1-2 weeks. A full-width front porch with integrated roofline and full railing system typically takes 3-5 weeks. We coordinate all required inspections and do not consider a project complete until it has received its certificate of occupancy."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Front porch projects typically start at $20,000+ in Northern Virginia, depending on the scope, size, materials, and roofline complexity. Projects involving HOA-required materials, custom column styles, or wraparound configurations are priced at the higher end. We provide a detailed itemized estimate at your free on-site consultation with no obligation to proceed."]}]]}],"$undefined"]}]
15:["$","div","3",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"HOA Compliance and Architectural Review in Northern Virginia"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Many neighborhoods in Loudoun and Fairfax County — Brambleton, Ashburn Village, Lansdowne on the Potomac, South Riding, and others — are governed by homeowner associations with architectural review boards that must approve exterior modifications including porch additions."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We have extensive experience navigating HOA architectural review processes in these communities. We can prepare the required submission documents, renderings, and material specifications on your behalf, and we design our porches to meet the specific material and color requirements of your community's governing documents."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Our recommendation: bring us your HOA's architectural guidelines at the outset of your project so we can design to spec from day one, avoiding revisions and delays. We have successfully completed permitted porch projects in dozens of planned communities across Northern Virginia."]}]]}],"$undefined"]}]
