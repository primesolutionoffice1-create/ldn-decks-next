31:["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Vinyl Windows",":"]}]," ",["Cost-effective, energy-efficient, and virtually maintenance-free; the #1 choice for NoVA families."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Fiberglass Windows",":"]}]," ",["Extremely strong, won't expand or contract, and allows for the largest possible glass views."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Wood Windows",":"]}]," ",["The premium aesthetic choice for historical homes and high-end luxury remodels."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Low-E Coatings",":"]}]," ",["Microscopic metallic layers that reflect heat while letting in natural light, mandatory for energy savings."]]}]]}]
32:["$","div","2",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Science of Comfort: Glass Technology and Insulation"}],["$","div",null,{"className":"$undefined","children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["The 'magic' of a modern window replacement lies in the glass. We primarily install double-pane units filled with Argon gas-a heavy, clear, non-toxic gas that acts as a powerful insulator between the panes. In high-stakes markets like Arlington and Herndon, adding Low-E (Low Emissivity) coatings can drastically reduce the amount of UV light entering your home. This does more than just lower your cooling bills; it prevents your furniture, flooring, and artwork from fading due to sun exposure."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Noise reduction is another major benefit of professional window installation. For our clients near Dulles Airport or busy corridors like I-66 and the Capital Beltway, we offer specialized sound-dampening glass packages. These use varied glass thicknesses and laminated layers to disrupt sound waves, turning a noisy street into a quiet sanctuary. This 5-Star functionality is what sets premium window systems apart from budget-grade alternatives."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We take pride in being a deck company near you that also understands the thermal dynamics of your home’s interior, providing a holistic approach to your property’s overall performance and value."]}]]}],"$undefined"]}]
33:["$","div","3",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Precision Installation: The Loudoun Decks Difference"}],["$","div",null,{"className":"$undefined","children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Even the most expensive window in the world will fail if it's not installed correctly. Shoddy installation leads to air leaks, water infiltration, and operational issues within just a few years. At Loudoun Decks, our installation protocol is rigorous. We use precision laser leveling to ensure every window is perfectly square and plumb. We utilize high-grade expanding foam and professional-grade flashing to create a triple-layered seal against Virginia's heavy rains."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We manage the entire project from initial measurements to final walkthrough. Our 'Full projects only' philosophy ensures that we are responsible for every detail, including the permit process in Stafford County and coordination with local building inspectors in Arlington. When we leave the job site, we ensure all debris is removed and your home is as clean as when we arrived, leaving only beautiful new views."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Choosing a 5-Star Google Rated contractor for your window replacement project means you are choosing peace of mind, professional communication, and a result that will look and perform flawlessly for decades."]}]]}],"$undefined"]}]
