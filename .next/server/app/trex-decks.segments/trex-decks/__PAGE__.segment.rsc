10:["$","ul",null,{"className":"ServiceContentExpansion-module__6_-y9q__detailsList","children":[["$","li","0",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Trex Transcend®",":"]}]," ",["The flagship line featuring high-definition wood grain and the most robust scratch-resistance."]]}],["$","li","1",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Trex Signature® Railing",":"]}]," ",["Powder-coated aluminum railing that offers slim profiles and maximum views of your yard."]]}],["$","li","2",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Trex RainEscape®",":"]}]," ",["An under-deck drainage system that allows you to create a dry living space beneath your elevated deck."]]}],["$","li","3",{"className":"ServiceContentExpansion-module__6_-y9q__listItem","children":[["$","strong",null,{"children":["Trex Outdoor Lighting™",":"]}]," ",["Post cap, stair riser, and recessed deck lights that are fully integrated into the Trex system."]]}]]}]
11:["$","div","2",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"The Science of Sustainability: 95% Recycled, 100% Luxury"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["In modern Northern Virginia, sustainability is more than just a buzzword-it is a priority. One of the reasons we are proud to be a Trex builder in regions like Vienna and Reston is Trex's commitment to the environment. Every Trex deck board is made from 95% recycled material, including reclaimed industrial wood scraps and recycled plastic film from grocery bags and dry cleaning wrap. Trex is one of the largest recyclers of plastic film in North America."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["This eco-friendly approach does not mean sacrificing quality. In fact, Trex material science produces a board that is more durable than natural wood. It won't splinter, making it much safer for bare feet and pets. It won't rot, even in the shaded, damp environments found in some parts of Prince William County and Stafford. You are essentially turning tons of waste into a permanent, high-value asset for your property."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["By choosing a 5-Star Google Rated Trex installer, you are supporting sustainable construction practices while ensuring your home features the world's most trusted name in outdoor living."]}]]}],"$undefined"]}]
12:["$","div","3",{"className":"ServiceContentExpansion-module__6_-y9q__textBlock","children":[["$","h3",null,{"className":"ServiceContentExpansion-module__6_-y9q__subTitle","children":"Integrated Features: Beyond the Deck Boards"}],["$","div",null,{"children":[["$","p","0",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["What separates a Loudoun Decks project from a standard installation is our use of the complete Trex ecosystem. For our elevated deck builds in Stafford and Arlington, we often recommend the Trex RainEscape system. This unique drainage system is installed over the joists and under the decking, diverting water away into a gutter system. This allows the area under the deck to stay completely dry, essentially creating a 'covered patio' for no-cost additional living space."]}],["$","p","1",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["We also specialize in Trex lighting. These low-voltage LED systems are designed to fit perfectly into Trex posts and stairs, providing a warm, sophisticated glow that enhances safety and allows you to enjoy your deck long after the sun goes down. As your custom deck builder, we handle all the electrical integration, ensuring your new outdoor space is fully ready for nighttime entertaining from day one."]}],["$","p","2",{"className":"ServiceContentExpansion-module__6_-y9q__paragraph","children":["Our 'Full projects only' approach ensures that your Trex deck is a complete, cohesive architectural statement that increases your home value and provides a lifetime of 5-Star memories."]}]]}],"$undefined"]}]
