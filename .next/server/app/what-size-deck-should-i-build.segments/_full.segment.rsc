1a:T45b,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the average deck size?","acceptedAnswer":{"@type":"Answer","text":"The average deck in Northern Virginia is 300-400 square feet. This fits a dining table for 6, a grill zone, and a seating area comfortably. Smaller decks (150-200 sqft) work for couples. Larger decks (500+ sqft) are common for families who entertain frequently."}},{"@type":"Question","name":"How big should my deck be for a dining table?","acceptedAnswer":{"@type":"Answer","text":"Allow 12x12 feet (144 sqft) minimum for a 6-person dining table with chairs and walking room. For 8 people, plan 12x14 (168 sqft). Always add 3-4 feet around the table for comfortable chair pull-out."}},{"@type":"Question","name":"How much of my yard should a deck take up?","acceptedAnswer":{"@type":"Answer","text":"A good rule: the deck should not exceed 20-25% of your total backyard area. In most Northern Virginia neighborhoods, this means 300-500 sqft on a typical quarter-acre lot. Check your county's lot coverage limits and HOA setback requirements."}}]}c:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],["$","section",null,{"style":{"background":"var(--color-dark)","color":"#fff","padding":"4rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","h1",null,{"style":{"fontSize":"2.5rem","fontWeight":700,"marginBottom":"1rem"},"children":"What Size Deck Should I Build?"}],["$","p",null,{"style":{"color":"#ccc","fontSize":"1.1rem"},"children":"Size recommendations by use case, household size, and Northern Virginia lot constraints"}]]}]}],["$","section",null,{"style":{"background":"#fff3e0","borderLeft":"4px solid var(--color-primary)","padding":"1.5rem 0"},"children":["$","div",null,{"style":{"maxWidth":900,"margin":"0 auto","padding":"0 1.5rem"},"children":[["$","p",null,{"style":{"fo