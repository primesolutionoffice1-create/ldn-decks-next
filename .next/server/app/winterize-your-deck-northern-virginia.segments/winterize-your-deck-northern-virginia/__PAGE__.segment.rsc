very board"]}],["$","br",null,{}],["$","span",null,{"style":{"color":"#555"},"children":"Look for: soft spots (poke with screwdriver), cracks, splits, popped nails/screws, loose boards. Fix before winter damage worsens with freeze-thaw."}]]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La"]}],"$Lb","$Lc","$Ld","$Le","$Lf","$L10",["$L11","$L12","$L13"],"$L14","$L15"]}]}],"$L16","$L17"],["$L18"],"$L19"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Jebrcr4Vyd2YosxlccnHN"}
